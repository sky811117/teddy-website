# ============================================================
# teddy-website 環境變數樣板
# ============================================================
# 複製本檔為 .env（本地開發）或設到 Cloudflare Pages → Settings →
# Environment variables（Production / Preview）。
#
# 規則：
#   - 變數名前綴 PUBLIC_ 才會打包到 client bundle、被 HTML 讀到
#   - 無前綴的（NOTION_API_KEY / CONTACT_TG_TOKEN）只在 Pages Functions
#     runtime 可讀、不會打進 client bundle（=不會洩漏給訪客）
#   - schema 定義在 astro.config.ts 的 env.schema（只管 PUBLIC_*）
#   - .env 已被 .gitignore 忽略，本檔 (.env.example) 才能進 git
# ============================================================

# ============================================================
# Client-side 變數（PUBLIC_* / 會打包到 HTML）
# ============================================================

# Google Search Console 驗證碼
# -----------------------------------------------------------
# 在 https://search.google.com/search-console 新增「網址前置字元」
# 資源後，會給一段 HTML 標籤驗證方法：
#   <meta name="google-site-verification" content="xxxxxxxx..." />
# 只填 content="..." 裡的那串值（不要含引號、不要含整個 tag）。
#
# 有值 → Layout.astro 會自動在 <head> 渲染 meta tag
# 沒值 → 整個 meta tag 不渲染（不影響其他功能）
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Formspree 表單 ID（給聯絡表單用 — 通用 ContactForm 的 email 通道）
# -----------------------------------------------------------
# https://formspree.io 建表單後拿到的 ID（form endpoint 末段）
# 例：xpwagrwo
# 注意：賣房表單 SellForm 不走 Formspree、直接寫 Notion + 推 TG
PUBLIC_FORMSPREE_FORM_ID=

# Cusdis comment system - register at https://cusdis.com
# -----------------------------------------------------------
# 部落格文末留言板（訪客可匿名留言、後台可審核），給非工程師客戶用。
# 1) 到 https://cusdis.com Google 登入並建立 site
# 2) 複製 App ID 填到 PUBLIC_CUSDIS_APP_ID
# 3) 自架 cusdis 才改 HOST，預設用官方雲端版即可
#
# 有值 → 文章頁底部會出現留言區
# 沒值 → Cusdis 區塊不渲染（不影響其他功能）
PUBLIC_CUSDIS_APP_ID=
PUBLIC_CUSDIS_HOST=https://cusdis.com

# ============================================================
# Server-side 變數（Cloudflare Pages Functions 用）
# ============================================================
# 這些只在 functions/ 底下的 .ts 檔被讀到、不會洩漏給 client。
# 本地用 wrangler dev 跑 Functions 時、寫到 .dev.vars 才會生效。
# 部署到 Cloudflare 時、必須去 Pages → Settings → Environment variables 設定。

# Notion Integration（給 /api/contact-sell 寫入賣房客戶名單用）
# -----------------------------------------------------------
# 1) 開 https://www.notion.so/profile/integrations → 「+ New integration」
#    - Name: teddy-website-sellform
#    - Associated workspace: 阿泰的 Notion 總部
#    - Type: Internal
# 2) 建好後複製 "Internal Integration Secret"（ntn_xxx 或 secret_xxx 開頭）
# 3) 到 Notion「賣房客戶名單」DB 頁面（在「泰迪開發工具」下）
#    右上 ⋯ → Connections → 加入 teddy-website-sellform integration
# 4) 把 secret 貼到下方（本地） + Cloudflare Pages 環境變數
NOTION_API_KEY=

# 賣房客戶名單 Database ID（已建好、固定值）
# -----------------------------------------------------------
NOTION_SELL_DB_ID=385edd7c9dc3438b94528327d4166255

# Telegram bot（給 /api/contact-tg 跟 /api/contact-sell 推通知用）
# -----------------------------------------------------------
# 推薦用「泰迪的小聲音」bot
# CONTACT_TG_CHAT 是景泰的 chat_id (905627471 之類)
CONTACT_TG_TOKEN=
CONTACT_TG_CHAT=
