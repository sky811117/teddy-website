---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { useTranslations } from "@/i18n";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const t = useTranslations(Astro.currentLocale);
const currentYear = new Date().getFullYear();
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class="border-border flex flex-col items-center gap-3 border-t py-5 sm:flex-row sm:justify-between"
  >
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
      <a
        href="https://line.me/ti/p/sky811117"
        class="hover:text-accent"
        title="LINE">💬 LINE</a
      >
      <a
        href="https://www.instagram.com/nov__817/"
        target="_blank"
        rel="noopener"
        class="hover:text-accent"
        title="Instagram">📷 IG</a
      >
      <a
        href="https://www.facebook.com/profile.php?id=61575492127872"
        target="_blank"
        rel="noopener"
        class="hover:text-accent"
        title="Facebook">📘 FB</a
      >
      <a
        href="https://www.youtube.com/@%E6%B3%B0%E8%BF%AA001"
        target="_blank"
        rel="noopener"
        class="hover:text-accent"
        title="YouTube">📺 YouTube</a
      >
      <a
        href="https://www.tiktok.com/@sky811117"
        target="_blank"
        rel="noopener"
        class="hover:text-accent"
        title="TikTok">🎬 TikTok</a
      >
    </div>
    <div class="text-muted-foreground text-sm whitespace-nowrap">
      &#169; {currentYear} 陳景泰
    </div>
  </div>
  <div
    class="text-muted-foreground border-border border-t py-3 text-center text-xs leading-relaxed"
  >
    <p>一品不動產 有巢氏房屋 台中世界之心加盟店</p>
    <p>
      經紀人 黃永隆 113彰縣字324 ・ 營業員 陳景泰 114登字488296 ・ 0920-118-756
    </p>
  </div>
</footer>
