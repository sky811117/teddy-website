---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ogImage, ...props } = data;

// cover image: 可能是 string (public 路徑) 或 image() object
const coverSrc =
  typeof ogImage === "string"
    ? ogImage
    : ogImage && "src" in ogImage
      ? ogImage.src
      : null;

const postUrl = getPostUrl(id, filePath, Astro.currentLocale);
---

<li class="my-6">
  <a
    href={postUrl}
    class:list={[
      "group block no-underline",
    ]}
  >
    {
      coverSrc && (
        <img
          src={coverSrc}
          alt={title}
          class="border-border mb-3 aspect-[16/9] w-full rounded-lg border object-cover transition-opacity group-hover:opacity-90"
          loading="lazy"
        />
      )
    }
    <Heading
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class:list={[
        "text-accent inline-block text-lg font-medium",
        "decoration-dashed underline-offset-4 group-hover:underline",
      ]}
    >
      {title}
    </Heading>
  </a>
  <Datetime {...props} />
  <p>{description}</p>
</li>
