---
import Layout from "./Layout.astro";
import config from "@/config";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  tags?: string[];
};

const { site } = config;

const {
  title,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags = [],
} = Astro.props;

// GA4 post tracking props
const postSlug = canonicalURL
  ? new URL(canonicalURL).pathname.replace(/\/$/, "").split("/").pop() ?? ""
  : Astro.url.pathname.replace(/\/$/, "").split("/").pop() ?? "";
const postTitle = title ?? "";
const postTags = tags.join(",");

// 強化 BlogPosting schema — 加 publisher / mainEntityOfPage / keywords / articleSection
const articleURL = canonicalURL ?? new URL(Astro.url.pathname, site.url).href;
const blogPosting = {
  "@type": "BlogPosting",
  "@id": `${articleURL}#article`,
  headline: title ?? site.title,
  description: description ?? site.description,
  image: ogImage,
  ...(pubDatetime && { datePublished: pubDatetime.toISOString() }),
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  author: {
    "@type": "Person",
    "@id": `${site.url}#realestateagent`,
    name: site.author,
    ...(site.profile && { url: site.profile }),
  },
  publisher: {
    "@type": "Organization",
    "@id": `${site.url}#organization`,
    name: "一品不動產 有巢氏房屋 台中世界之心加盟店",
    logo: {
      "@type": "ImageObject",
      url: `${site.url}logos/yochaoshi.png`,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": articleURL,
  },
  inLanguage: "zh-TW",
  ...(tags.length > 0 && { keywords: tags.join(", ") }),
  articleSection: "房地產",
};

// BreadcrumbList — Home > Posts > 文章標題
const breadcrumbList = {
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "首頁",
      item: site.url,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "房市筆記",
      item: `${site.url}posts/`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
    },
  ],
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [blogPosting, breadcrumbList],
};
---

<Layout {title} {description} {ogImage} {canonicalURL}>
  <Fragment slot="head">
    <!-- Override og:type for article pages -->
    <meta property="og:type" content="article" />

    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }
    {tags.map(tag => <meta property="article:tag" content={tag} />)}

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- GA4: 文章閱讀 + 停留時間追蹤 -->
    <script is:inline define:vars={{ postSlug, postTitle, postTags }}>
      function _gaConsented() {
        return localStorage.getItem("ga_consent") === "granted";
      }
      function _sendIfConsented(fn) {
        if (_gaConsented()) { fn(); }
        else { window.addEventListener("ga:consented", fn, { once: true }); }
      }

      // read_post：進入文章頁即記錄
      _sendIfConsented(function () {
        if (window.gtag) gtag("event", "read_post", {
          post_slug: postSlug,
          post_title: postTitle,
          post_tags: postTags,
        });
      });

      // dwell timers：30s / 60s / 120s，Page Visibility API 確認使用者在看
      [30, 60, 120].forEach(function (sec) {
        setTimeout(function () {
          if (document.visibilityState !== "visible") return;
          _sendIfConsented(function () {
            if (window.gtag) gtag("event", "dwell_" + sec, {
              post_slug: postSlug,
            });
          });
        }, sec * 1000);
      });
    </script>
  </Fragment>

  <slot />
</Layout>
