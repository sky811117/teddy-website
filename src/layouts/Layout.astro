---
import { Font } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";
import { resolveDefaultOgImagePath } from "@/utils/resolveDefaultOgImagePath";
import { getAssetPath } from "@/utils/withBase";
import { safeJsonLd } from "@/utils/safeJsonLd";
import FloatingCTA from "@/components/FloatingCTA.astro";
import Analytics from "@/components/Analytics.astro";
import config from "@/config";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  noindex?: boolean;
  prevURL?: string;
  nextURL?: string;
};

const { site } = config;

const {
  title = site.title,
  description = site.description,
  ogImage = resolveDefaultOgImagePath(config),
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  noindex = false,
  prevURL,
  nextURL,
} = Astro.props;

const socialImageURL = new URL(ogImage, Astro.site ?? Astro.url);
const rssHref = getRelativeLocaleUrl(
  Astro.currentLocale ?? config.site.lang,
  "rss.xml"
);
---

<!doctype html>
<html
  dir={site.dir ?? "ltr"}
  lang={Astro.currentLocale ?? site.lang}
  class="overflow-y-scroll scroll-smooth"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={getAssetPath("favicon.svg")} />
    <link rel="icon" href={getAssetPath("favicon.ico")} />
    <link rel="apple-touch-icon" href={getAssetPath("favicon.svg")} />
    <link rel="manifest" href={getAssetPath("manifest.json")} />
    <link rel="canonical" href={canonicalURL} />
    {prevURL && <link rel="prev" href={prevURL} />}
    {nextURL && <link rel="next" href={nextURL} />}
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="generator" content={Astro.generator} />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="景泰房仲" />

    <!-- Preconnect / DNS-prefetch 第三方資源（GA / fonts） -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://line.me" />

    <!-- Font -->
    <Font
      cssVariable="--font-google-sans-code"
      preload={[{ subset: "latin", weight: 400, style: "normal" }]}
    />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <link rel="sitemap" href={getAssetPath("sitemap-index.xml")} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="zh_TW" />

    <!-- Twitter / X -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />
    <meta property="twitter:image:alt" content={title} />

    <!-- RSS autodiscovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={site.title}
      href={new URL(rssHref, Astro.site)}
    />

    <!-- Theme color：對 light / dark mode 各設 default，theme.ts runtime 會覆蓋成精確值 -->
    <meta name="theme-color" content="#f5f1eb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1f1b17" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="" />

    <!-- JSON-LD: 多 schema @graph（影響 Google 搜尋呈現） -->
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "RealEstateAgent",
            "@id": `${site.url}#realestateagent`,
            name: "陳景泰",
            alternateName: ["Teddy Chen", "Teddy", "泰迪", "景泰", "房仲大看板 泰迪"],
            url: site.url,
            image: socialImageURL.href,
            telephone: "+886-920-118-756",
            email: "a0920118756@gmail.com",
            jobTitle: "不動產營業員 Real Estate Agent",
            worksFor: { "@id": `${site.url}#organization` },
            memberOf: {
              "@type": "Organization",
              name: "房仲大看板 BigKanBan",
              alternateName: ["BigKanBan", "大看板"],
              url: "https://instagram.com/bigkanban",
            },
            address: {
              "@type": "PostalAddress",
              addressLocality: "台中市",
              addressRegion: "Taichung",
              addressCountry: "TW",
            },
            sameAs: [
              "https://line.me/ti/p/sky811117",
              "https://instagram.com/nov__817",
              "https://www.facebook.com/profile.php?id=61575492127872",
              "https://www.youtube.com/@%E6%B3%B0%E8%BF%AA001",
              "https://www.tiktok.com/@sky811117",
            ],
            knowsAbout: [
              "台中房地產",
              "台中買房",
              "台中賣房",
              "北屯區房屋",
              "西屯區房屋",
              "南屯區房屋",
              "七期房屋",
              "新青安貸款",
              "房屋估價",
              "合理出價",
              "嫌惡設施",
              "不動產說明書",
              "房屋實價登錄",
              "房仲業務",
              "AI 自動化",
            ],
            areaServed: [
              { "@type": "City", name: "台中市", alternateName: "Taichung" },
              { "@type": "AdministrativeArea", name: "北屯區" },
              { "@type": "AdministrativeArea", name: "西屯區" },
              { "@type": "AdministrativeArea", name: "南屯區" },
              { "@type": "AdministrativeArea", name: "七期" },
              { "@type": "AdministrativeArea", name: "中區" },
              { "@type": "AdministrativeArea", name: "太平區" },
              { "@type": "AdministrativeArea", name: "大里區" },
            ],
            hasCredential: [
              "經紀人 黃永隆 113彰縣字324",
              "營業員 陳景泰 114登字488296",
            ],
            priceRange: "$$$",
          },
          {
            "@type": "RealEstateAgent",
            "@id": `${site.url}#organization`,
            name: "一品不動產 有巢氏房屋 台中世界之心加盟店",
            alternateName: "有巢氏房屋 世界之心店",
            url: site.url,
            logo: `${site.url}logos/yochaoshi.png`,
            telephone: "+886-4-2312-0888",
            address: {
              "@type": "PostalAddress",
              addressLocality: "台中市",
              addressRegion: "Taichung",
              addressCountry: "TW",
            },
            // 標準營業時間：週一到週日 09:00-21:00 (房仲業典型)
            openingHoursSpecification: [
              {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: [
                  "Monday",
                  "Tuesday",
                  "Wednesday",
                  "Thursday",
                  "Friday",
                  "Saturday",
                  "Sunday",
                ],
                opens: "09:00",
                closes: "21:00",
              },
            ],
            areaServed: [
              { "@type": "City", name: "台中市" },
              { "@type": "AdministrativeArea", name: "南投縣" },
              { "@type": "AdministrativeArea", name: "彰化縣" },
              { "@type": "AdministrativeArea", name: "苗栗縣" },
            ],
            employee: {
              "@id": `${site.url}#realestateagent`,
            },
            parentOrganization: {
              "@type": "Organization",
              name: "有巢氏房屋",
              url: "https://www.yungching.com.tw/",
            },
          },
          {
            "@type": "WebSite",
            "@id": `${site.url}#website`,
            url: site.url,
            name: site.title,
            description: site.description,
            inLanguage: "zh-TW",
            publisher: { "@id": `${site.url}#organization` },
            potentialAction: {
              "@type": "SearchAction",
              target: {
                "@type": "EntryPoint",
                urlTemplate: `${site.url}search?q={search_term_string}`,
              },
              "query-input": "required name=search_term_string",
            },
          },
        ],
      })}
    />

    <!-- Extra head content injected by child layouts (e.g. JSON-LD, article meta) -->
    <slot name="head" />

    {
      site.googleVerification && (
        <meta
          name="google-site-verification"
          content={site.googleVerification}
        />
      )
    }

    <Analytics />

    <!--
      Inline FOUC-prevention script: sets data-theme on <html> before
      the browser paints. Runs synchronously, no defer/async.
    -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const theme = stored ?? (prefersDark ? "dark" : "light");
        document.firstElementChild?.setAttribute("data-theme", theme);
        // Expose value so theme.ts can skip re-detection.
        window.__theme = { value: theme };
      })();
    </script>

  </head>
  <body
    class="bg-background font-app text-foreground selection:bg-accent/75 selection:text-accent-foreground flex min-h-svh flex-col"
  >
    <slot />
    <FloatingCTA />
    <script>
      import "@/scripts/theme";
    </script>
  </body>
</html>
