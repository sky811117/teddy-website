---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SellForm from "@/components/SellForm.astro";
import config from "@/config";
import { safeJsonLd } from "@/utils/safeJsonLd";

const canonicalURL = new URL("/sell", Astro.site).href;
const siteOrigin = new URL("/", Astro.site).href;
const realEstateAgentId = `${siteOrigin}#realestateagent`;

const metaTitle = `台中賣房委託 — AI 修圖 + 多平台曝光 | ${config.site.title}`;
const metaDesc =
  "台中賣房委託景泰：AI 修圖讓物件照更好看、591 / 樂屋 / 5168 多平台同步、公司自媒體 BigKanBan 跨平台曝光。先給你一個合理估價區間，再決定要不要委託。LINE：sky811117。";

// 為什麼委託景泰（三點，勿誇大）
const reasons = [
  {
    emoji: "🤖",
    title: "AI 修圖，物件照更好看",
    desc: "同一間房，照片拍得好不好，買家點不點進來差很多。我用 AI 工具把物件照調亮、調正，讓你的房子在一排縮圖裡更容易被點開。",
  },
  {
    emoji: "📡",
    title: "591 / 樂屋 / 5168 多平台同步",
    desc: "上架不是只丟一個平台。三大平台我都自動化同步，照片、文案、價格一次到位，買家在哪個平台找都看得到你的物件。",
  },
  {
    emoji: "📣",
    title: "公司自媒體 BigKanBan 曝光",
    desc: "我所在公司經營房仲自媒體 IP，IG 主帳 11K 粉、跨 IG / TikTok / FB。你的物件曝光不只一個房仲在做，是一整個團隊。",
  },
];

// 委託流程 4 步
const steps = [
  {
    emoji: "📊",
    title: "1. 免費估價",
    desc: "看實價登錄成交 + 同社區在售 + 屋況加減項，給你一個合理區間（不是單一價、是區間）。沒委託壓力，先看數字再說。",
  },
  {
    emoji: "🖼️",
    title: "2. AI 修圖上架",
    desc: "物件照 AI 修圖、寫文案，591 / 樂屋 / 5168 多平台同步上架，公司自媒體一起幫你推。",
  },
  {
    emoji: "🤝",
    title: "3. 看屋議價",
    desc: "幫你篩掉純看熱鬧的、安排有意願的買家。出價進來，用同社區行情幫你判斷該守還是該放。",
  },
  {
    emoji: "📝",
    title: "4. 簽約過戶",
    desc: "簽約、履約保證、過戶、點交全程陪同，該注意的條款一條一條跟你確認清楚。",
  },
];

// 語料複用 services.astro 的 sell.targetUsers
const targetUsers = [
  "急售族（時間敏感、要快速成交）",
  "換屋族（要先賣 + 同步買新）",
  "投資出場族（算稅後利潤）",
  "繼承族（不熟流程、要全程協助）",
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${canonicalURL}#service`,
  name: "台中賣房委託",
  description:
    "AI 修圖、591 / 樂屋 / 5168 多平台同步、公司自媒體曝光，從免費估價區間到簽約過戶的全程賣房協助。",
  serviceType: "賣房協助",
  provider: { "@id": realEstateAgentId },
  areaServed: {
    "@type": "City",
    name: "台中市",
  },
  audience: {
    "@type": "PeopleAudience",
    suggestedAudience: targetUsers,
  },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "賣房協助內容",
    itemListElement: [
      "免費估價（給合理區間、不是單一價）",
      "物件照 AI 修圖",
      "591 / 樂屋 / 5168 多平台同步上架",
      "公司自媒體 BigKanBan 跨平台曝光",
      "看屋議價 + 簽約過戶全程協助",
    ].map((item, idx) => ({
      "@type": "Offer",
      position: idx + 1,
      itemOffered: {
        "@type": "Service",
        name: item,
      },
    })),
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "首頁",
      item: siteOrigin,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "台中賣房委託",
      item: canonicalURL,
    },
  ],
};
---

<Layout title={metaTitle} description={metaDesc} canonicalURL={canonicalURL}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(serviceSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(breadcrumbSchema)}
    />
  </Fragment>

  <Header />

  <main id="main-content" class="app-layout">
    {/* ============ HERO ============ */}
    <section class="border-border border-b py-12 text-center sm:py-16">
      <h1 class="text-3xl font-bold sm:text-4xl">
        想賣房，<br />
        <span class="text-accent">先看一個合理的估價區間</span>
      </h1>
      <p
        class="text-muted-foreground mx-auto mt-6 max-w-xl text-[17px] leading-relaxed"
      >
        賣房怕兩件事：賣太便宜虧到，或掛太高賣不掉。
        我先用實價登錄 + 同社區在售，給你一個合理區間，你看完數字再決定要不要委託。
        要委託的話，AI 修圖、多平台同步、公司自媒體曝光一起上，讓對的買家看到你的房子。
      </p>

      <div
        class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
      >
        <a
          href="https://line.me/ti/p/sky811117"
          class="bg-accent text-accent-foreground rounded-lg px-6 py-3 text-[17px] font-medium no-underline shadow hover:shadow-lg"
        >
          💰 想賣房（LINE 諮詢）
        </a>
        <a
          href="#sell-form-section"
          class="border-accent text-accent rounded-lg border-2 px-6 py-3 text-[17px] font-medium no-underline hover:bg-accent hover:text-accent-foreground"
        >
          📝 填表單拿估價 ↓
        </a>
      </div>
    </section>

    {/* ============ 為什麼委託景泰 ============ */}
    <section class="border-border border-b py-12 sm:py-16">
      <div class="text-center">
        <p class="text-muted-foreground text-sm">為什麼委託景泰</p>
        <h2 class="text-foreground mt-2 text-2xl font-bold sm:text-3xl">
          同樣賣一間房，多了這三件事
        </h2>
      </div>
      <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
        {
          reasons.map(r => (
            <li class="border-border bg-card rounded-lg border p-6">
              <div class="text-4xl">{r.emoji}</div>
              <h3 class="text-foreground mt-3 text-xl font-bold">{r.title}</h3>
              <p class="text-muted-foreground mt-2 text-[15px] leading-relaxed">
                {r.desc}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    {/* ============ 委託流程 ============ */}
    <section class="border-border border-b py-12 sm:py-16">
      <div class="text-center">
        <p class="text-muted-foreground text-sm">委託流程</p>
        <h2 class="text-foreground mt-2 text-2xl font-bold sm:text-3xl">
          從估價到過戶，4 步
        </h2>
      </div>
      <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          steps.map(s => (
            <li class="border-border bg-card rounded-lg border p-6">
              <div class="text-4xl">{s.emoji}</div>
              <h3 class="text-foreground mt-3 text-xl font-bold">{s.title}</h3>
              <p class="text-muted-foreground mt-2 text-[15px] leading-relaxed">
                {s.desc}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    {/* ============ 適合誰找 ============ */}
    <section class="border-border border-b py-12 sm:py-16">
      <div class="border-border bg-card rounded-lg border p-6 sm:p-8">
        <h2 class="text-foreground text-xl font-bold sm:text-2xl">
          🎯 這些人適合找我賣
        </h2>
        <ul class="text-muted-foreground mt-4 grid grid-cols-1 gap-2 text-[15px] leading-relaxed sm:grid-cols-2">
          {targetUsers.map(u => <li>・{u}</li>)}
        </ul>
      </div>
    </section>

    {/* ============ 底部表單 ============ */}
    <div id="sell-form-section">
      <SellForm
        title="留屋況給景泰，24 小時內回估價區間"
        subtitle="區 + 路段 + 坪數 + 期望總價就好，巷弄門牌可暫時不寫。資料只進景泰個人 CRM、不會給第三方。"
      />
    </div>
  </main>

  <Footer />
</Layout>
