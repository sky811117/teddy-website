<script is:inline>
  (function () {
    const btn = document.querySelector("[data-hero-search]");
    if (!btn) return;
    function go() {
      const district =
        document.querySelector("[data-hero-district]")?.value || "";
      const priceMax =
        document.querySelector("[data-hero-price-max]")?.value || "";
      const rooms = document.querySelector("[data-hero-rooms]")?.value || "";
      const params = new URLSearchParams();
      if (district) params.set("district", district);
      if (priceMax) params.set("priceMax", priceMax);
      if (rooms) params.set("rooms", rooms);
      const qs = params.toString();
      location.href = "/properties" + (qs ? "?" + qs : "");
    }
    btn.addEventListener("click", go);
    // Enter 鍵在 input 內也觸發
    document
      .querySelector("[data-hero-price-max]")
      ?.addEventListener("keydown", e => {
        if (e.key === "Enter") {
          e.preventDefault();
          go();
        }
      });
  })();
</script>
