---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Testimonials from "@/components/Testimonials.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { safeJsonLd } from "@/utils/safeJsonLd";
import { isTaichung } from "@/utils/isTaichung";
import config from "@/config";

// ===== icon（Tabler outline SVG，全站 emoji 已換成這套）=====
import IconRobot from "@/assets/icons/IconRobot.svg";
import IconSpeakerphone from "@/assets/icons/IconSpeakerphone.svg";
import IconMapPin from "@/assets/icons/IconMapPin.svg";
import IconNotes from "@/assets/icons/IconNotes.svg";
import IconHome from "@/assets/icons/IconHome.svg";
import IconCalculator from "@/assets/icons/IconCalculator.svg";
import IconHelpCircle from "@/assets/icons/IconHelpCircle.svg";
import IconTool from "@/assets/icons/IconTool.svg";
import IconDeviceTv from "@/assets/icons/IconDeviceTv.svg";
import IconPhone from "@/assets/icons/IconPhone.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconBuildingCommunity from "@/assets/icons/IconBuildingCommunity.svg";
import IconCheck from "@/assets/icons/IconCheck.svg";
import IconCoin from "@/assets/icons/IconCoin.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import IconBrandLine from "@/assets/icons/socials/line.svg";
import IconBrandInstagram from "@/assets/icons/socials/instagram.svg";
import IconBrandFacebook from "@/assets/icons/socials/facebook.svg";
import IconBrandYoutube from "@/assets/icons/socials/youtube.svg";
import IconBrandTiktok from "@/assets/icons/socials/tiktok.svg";

const locale = Astro.currentLocale ?? config.site.lang;

// 首頁房市筆記 section：featured 優先，不夠 3 篇補最新
const posts = await getCollection("posts", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(p => p.data.featured);
const recentPosts = [
  ...featuredPosts.slice(0, 3),
  ...sortedPosts
    .filter(p => !p.data.featured)
    .slice(0, Math.max(0, 3 - featuredPosts.length)),
].slice(0, 3);

// 在售精選 3 筆（空 collection 時不顯示）
const allProperties = await getCollection(
  "properties",
  ({ data }) => data.status === "active"
).catch(() => []);
// 有封面照優先（首頁門面不能擺 placeholder）> 台中優先（台中房仲門面）> 最新
const featuredProperties = allProperties
  .sort(
    (a, b) =>
      Number(Boolean(b.data.coverImage)) - Number(Boolean(a.data.coverImage)) ||
      Number(isTaichung(b.data.district)) - Number(isTaichung(a.data.district)) ||
      b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime()
  )
  .slice(0, 3);

// ===== 客戶見證（Phase 3 預留）=====
// 目前傳空陣列 → Testimonials 元件不渲染。
// 之後有真實見證，照下面範例格式填入就會自動顯示：
// ⚠️ 必須是「真實客戶 + 取得刊登授權」，不可虛構、不可改寫客戶原話語意。
// const testimonials = [
//   {
//     name: "王太太",            // 姓氏 + 稱謂即可，不公開全名
//     role: "北屯首購夫妻",       // 身分標籤
//     quote: "（客戶授權的原話）", // 見證引文
//     dealType: "買方成交",       // 成交類型
//   },
// ];
const testimonials: {
  name: string;
  role: string;
  quote: string;
  dealType: string;
}[] = [];

const personalAccounts = [
  {
    platform: "Instagram",
    handle: "@nov__817",
    desc: "主帳號 · 房仲日常",
    url: "https://www.instagram.com/nov__817/",
    icon: IconBrandInstagram,
  },
  {
    platform: "Facebook",
    handle: "陳景泰",
    desc: "日常 + 業務分享",
    url: "https://www.facebook.com/profile.php?id=61575492127872",
    icon: IconBrandFacebook,
  },
  {
    platform: "YouTube",
    handle: "@泰迪001",
    desc: "房屋開箱 + 看屋",
    url: "https://www.youtube.com/@%E6%B3%B0%E8%BF%AA001",
    icon: IconBrandYoutube,
  },
  {
    platform: "TikTok",
    handle: "@sky811117",
    desc: "短影音 + 快剪",
    url: "https://www.tiktok.com/@sky811117",
    icon: IconBrandTiktok,
  },
  {
    platform: "LINE",
    handle: "sky811117",
    desc: "私訊（30 秒-30 分回）",
    url: "https://line.me/ti/p/sky811117",
    icon: IconBrandLine,
  },
];

// 首頁 WebPage + SiteNavigationElement schema
const siteOrigin = new URL("/", Astro.site).href;
const homePageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteOrigin}#webpage`,
  url: siteOrigin,
  name: config.site.title,
  description: config.site.description,
  isPartOf: { "@id": `${siteOrigin}#website` },
  about: { "@id": `${siteOrigin}#realestateagent` },
  inLanguage: "zh-TW",
  significantLink: [
    `${siteOrigin}properties`,
    `${siteOrigin}posts`,
    `${siteOrigin}faq`,
    `${siteOrigin}services`,
    `${siteOrigin}tools`,
    `${siteOrigin}areas`,
    `${siteOrigin}contact`,
    `${siteOrigin}about`,
  ],
};

// SiteNavigationElement — 給 Google 認得主導航結構，可能進 sitelinks
const navSchema = {
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  name: "主導航",
  hasPart: [
    { "@type": "WebPage", name: "在售物件", url: `${siteOrigin}properties` },
    { "@type": "WebPage", name: "房市筆記", url: `${siteOrigin}posts` },
    { "@type": "WebPage", name: "客戶工具", url: `${siteOrigin}tools` },
    { "@type": "WebPage", name: "常見問題", url: `${siteOrigin}faq` },
    { "@type": "WebPage", name: "台中各區", url: `${siteOrigin}areas` },
    { "@type": "WebPage", name: "服務項目", url: `${siteOrigin}services` },
    { "@type": "WebPage", name: "找景泰", url: `${siteOrigin}media` },
    { "@type": "WebPage", name: "關於景泰", url: `${siteOrigin}about` },
    { "@type": "WebPage", name: "聯絡景泰", url: `${siteOrigin}contact` },
  ],
};

const bigKanBanAccounts = [
  {
    platform: "Instagram",
    handle: "@bigkanban",
    desc: "主帳號 · 11K 粉絲",
    url: "https://instagram.com/bigkanban",
    icon: IconBrandInstagram,
  },
  {
    platform: "Instagram",
    handle: "@bigkanban.boss",
    desc: "BOSS 本尊個人帳",
    url: "https://instagram.com/bigkanban.boss",
    icon: IconBrandInstagram,
  },
  {
    platform: "TikTok",
    handle: "@bigkanban2.0",
    desc: "房屋開箱短影音",
    url: "https://www.tiktok.com/@bigkanban2.0",
    icon: IconBrandTiktok,
  },
  {
    platform: "Facebook",
    handle: "BigKanBan 粉專",
    desc: "深度長文+物件",
    url: "https://www.facebook.com/bigkanban",
    icon: IconBrandFacebook,
  },
];
---

<Layout>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(homePageSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(navSchema)}
    />
  </Fragment>

  <Header />

  <main id="main-content" class="w-full">
    {/* ============ SECTION 1: HERO（桌機兩欄：左文字+搜尋 / 右視覺面板） ============ */}
    <section id="hero" class="w-full">
      <div class="app-layout-wide py-10 sm:py-14 lg:py-16">
        <div
          class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-12"
        >
          {/* --- 左欄：標題 + 副文 + 快速搜尋 + CTA --- */}
          <div class="text-left">
            <div class="flex items-center gap-3">
              <img
                src="/photos/teddy-avatar.jpg"
                alt="陳景泰 / 泰迪 — 台中房仲"
                width="40"
                height="40"
                class="border-accent size-10 rounded-full border-2 object-cover"
                loading="eager"
              />
              <p class="text-muted-foreground text-sm tracking-wide">
                陳景泰 / 泰迪 Teddy
              </p>
            </div>

            <h1 class="mt-5 text-4xl font-bold sm:text-5xl lg:text-6xl">
              <span class="inline-block">在台中買房 /</span> <span class="inline-block">賣房，</span><br />
              <span class="text-accent">用 AI 找到對的答案</span>
            </h1>

            <p class="text-muted-foreground mt-6 max-w-xl text-lg leading-relaxed">
              我是<strong class="text-foreground">陳景泰</strong>，台中房仲。短影音上叫<strong class="text-foreground">泰迪</strong> — 在公司自媒體<a href="/media" class="text-accent underline underline-offset-2 hover:no-underline">房仲大看板 BigKanBan</a> 團隊也是這個名字。<br />
              一邊跑業務，一邊用 Claude Code 把整套工作自動化 —
              讓你的物件多平台曝光、看屋資料整齊、決策有 AI 算過。
            </p>

            {/* 快速搜尋 bar — 跳 /properties 帶 query string */}
            <div class="card-surface mt-8 p-4 text-left sm:p-5">
              <div
                class="text-muted-foreground mb-3 flex items-center gap-1.5 text-xs font-medium"
              >
                <IconSearch class="size-4" aria-hidden="true" />
                快速找物件
              </div>
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
                <label class="sr-only" for="hero-district">區域</label>
                <select
                  id="hero-district"
                  data-hero-district
                  class="border-border bg-background text-foreground focus:border-accent focus:ring-accent/30 block w-full rounded-md border px-4 py-3 text-[17px] outline-none focus:ring-2"
                >
                  <option value="">區域（不限）</option>
                  <option value="北屯區">北屯區</option>
                  <option value="西屯區">西屯區</option>
                  <option value="南屯區">南屯區</option>
                  <option value="北區">北區</option>
                  <option value="南區">南區</option>
                  <option value="東區">東區</option>
                  <option value="西區">西區</option>
                  <option value="中區">中區</option>
                  <option value="太平區">太平區</option>
                  <option value="大里區">大里區</option>
                  <option value="霧峰區">霧峰區</option>
                </select>

                <label class="sr-only" for="hero-price-max">總價上限</label>
                <input
                  id="hero-price-max"
                  type="number"
                  inputmode="numeric"
                  min="0"
                  step="100"
                  placeholder="總價上限（萬）"
                  data-hero-price-max
                  class="border-border bg-background text-foreground focus:border-accent focus:ring-accent/30 block w-full rounded-md border px-4 py-3 text-[17px] outline-none focus:ring-2"
                />

                <label class="sr-only" for="hero-rooms">房型</label>
                <select
                  id="hero-rooms"
                  data-hero-rooms
                  class="border-border bg-background text-foreground focus:border-accent focus:ring-accent/30 block w-full rounded-md border px-4 py-3 text-[17px] outline-none focus:ring-2"
                >
                  <option value="">房型（不限）</option>
                  <option value="1房">1 房</option>
                  <option value="2房">2 房</option>
                  <option value="3房">3 房</option>
                  <option value="4房">4 房</option>
                  <option value="5房+">5 房以上</option>
                </select>
              </div>

              <button type="button" data-hero-search class="btn-primary mt-3 w-full">
                <IconSearch class="size-5" aria-hidden="true" />
                搜尋
              </button>

              {/* 常用搜尋 chips — 一鍵跳到熱門條件結果 */}
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="text-muted-foreground self-center text-xs">熱門：</span>
                <a
                  href="/properties?priceMax=1000"
                  class="border-border bg-background text-foreground hover:border-accent hover:text-accent inline-block rounded-full border px-3 py-1 text-xs no-underline transition-colors"
                >
                  新青安額度內（≤1000 萬）
                </a>
                <a
                  href="/properties?district=%E5%8C%97%E5%B1%AF%E5%8D%80"
                  class="border-border bg-background text-foreground hover:border-accent hover:text-accent inline-block rounded-full border px-3 py-1 text-xs no-underline transition-colors"
                >
                  北屯
                </a>
                <a
                  href="/properties?district=%E8%A5%BF%E5%B1%AF%E5%8D%80"
                  class="border-border bg-background text-foreground hover:border-accent hover:text-accent inline-block rounded-full border px-3 py-1 text-xs no-underline transition-colors"
                >
                  西屯 / 七期
                </a>
                <a
                  href="/properties?district=%E5%8D%97%E5%B1%AF%E5%8D%80"
                  class="border-border bg-background text-foreground hover:border-accent hover:text-accent inline-block rounded-full border px-3 py-1 text-xs no-underline transition-colors"
                >
                  南屯
                </a>
                <a
                  href="/properties?quick=new"
                  class="border-border bg-background text-foreground hover:border-accent hover:text-accent inline-block rounded-full border px-3 py-1 text-xs no-underline transition-colors"
                >
                  新上架
                </a>
                <a
                  href="/properties?quick=drop"
                  class="border-border bg-background text-foreground hover:border-accent hover:text-accent inline-block rounded-full border px-3 py-1 text-xs no-underline transition-colors"
                >
                  降價中
                </a>
                <a
                  href="/properties?ageMax=5"
                  class="border-border bg-background text-foreground hover:border-accent hover:text-accent inline-block rounded-full border px-3 py-1 text-xs no-underline transition-colors"
                >
                  新成屋（≤5 年）
                </a>
              </div>
            </div>

            {/* 買 / 賣 雙 CTA */}
            <div class="mt-8 grid max-w-lg grid-cols-1 gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-2">
                <a
                  href="https://line.me/ti/p/sky811117"
                  class="btn-line w-full"
                >
                  <IconBrandLine class="size-5" aria-hidden="true" />
                  我要找房（LINE 諮詢）
                </a>
                <a
                  href="/contact?type=buy"
                  class="text-muted-foreground hover:text-accent text-center text-[14px] underline-offset-2 hover:underline"
                >
                  或填表單留資料 →
                </a>
              </div>
              <div class="flex flex-col gap-2">
                <a href="/contact?type=sell" class="btn-outline w-full">
                  我要賣房（填委託表單）
                </a>
                <a
                  href="https://line.me/ti/p/sky811117"
                  class="text-muted-foreground hover:text-accent text-center text-[14px] underline-offset-2 hover:underline"
                >
                  或 LINE 先聊聊 →
                </a>
              </div>
            </div>

            {/* 顯式電話 CTA — Layout 設了 format-detection telephone=no，手機要靠這條才撥得通 */}
            <div class="mt-6 flex max-w-lg flex-col gap-2">
              <a
                href="tel:+886920118756"
                class="border-border bg-card hover:border-accent hover:text-accent rounded-btn text-foreground inline-flex min-h-11 w-full items-center justify-center gap-2 border-2 px-6 py-3 text-lg font-semibold no-underline transition-colors sm:w-auto"
                data-track="cta"
                data-cta="hero-tel"
              >
                <IconPhone class="size-5" aria-hidden="true" />
                0920-118-756
              </a>
              <p class="text-muted-foreground text-[14px]">
                急約看屋、想直接講？這支號碼直撥本人
              </p>
            </div>
          </div>

          {/* --- 右欄：視覺面板（台中空拍主視覺；人像合成觀感不佳已撤，
               等景泰有新形象照再評估要不要疊回來） --- */}
          <div class="mx-auto w-full max-w-xs sm:max-w-sm lg:mx-0 lg:max-w-none">
            <div
              class="rounded-card shadow-card-hover relative aspect-[4/5] w-full overflow-hidden"
            >
              {/* 主視覺：秋紅谷 + 七期天際線空拍 */}
              <picture>
                <source srcset="/photos/hero-aerial.webp" type="image/webp" />
                <img
                  src="/photos/hero-aerial.jpg"
                  alt="台中七期天際線與秋紅谷空拍"
                  width="900"
                  height="1125"
                  class="absolute inset-0 h-full w-full object-cover"
                  loading="eager"
                  fetchpriority="high"
                />
              </picture>
              {/* 底部淡漸層 — 給地點標籤一點對比 */}
              <div
                class="absolute inset-x-0 bottom-0 h-1/4 bg-gradient-to-t from-black/35 to-transparent"
                aria-hidden="true"
              >
              </div>
              {/* 地點標籤 — 在地識別 */}
              <p
                class="absolute bottom-4 left-4 flex items-center gap-1.5 rounded-full bg-black/35 px-3 py-1.5 text-sm font-medium text-white backdrop-blur-sm"
              >
                <IconMapPin class="size-4" aria-hidden="true" />
                台中・秋紅谷｜七期天際線
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ============ SECTION 1.2: 信任數據條（白底橫帶 + 有巢氏品牌證號） ============ */}
    <section class="border-border bg-card w-full border-y">
      <div class="app-layout-wide py-8 sm:py-10">
        <div class="divide-border grid grid-cols-2 divide-x sm:grid-cols-4">
          <div class="px-4 py-3 text-center">
            <p class="text-accent text-2xl font-extrabold leading-tight whitespace-nowrap sm:text-3xl">
              {allProperties.length}+
            </p>
            <p class="text-muted-foreground mt-1 text-sm">筆在售物件</p>
          </div>
          <div class="px-4 py-3 text-center">
            <p class="text-accent text-2xl font-extrabold leading-tight whitespace-nowrap sm:text-3xl">
              11 區
            </p>
            <p class="text-muted-foreground mt-1 text-sm">台中全區覆蓋</p>
          </div>
          <div class="px-4 py-3 text-center">
            <p class="text-accent text-2xl font-extrabold leading-tight whitespace-nowrap sm:text-3xl">
              30秒-30分
            </p>
            <p class="text-muted-foreground mt-1 text-sm">LINE 回覆</p>
          </div>
          <div class="px-4 py-3 text-center">
            <p class="text-accent text-2xl font-extrabold leading-tight whitespace-nowrap sm:text-3xl">
              有巢氏
            </p>
            <p class="text-muted-foreground mt-1 text-sm">世界之心加盟店</p>
          </div>
        </div>

        {/* 信任 badge — 有巢氏品牌 + 法定證號（內容一字不動） */}
        <div
          class="border-border mt-8 flex flex-col items-center justify-center gap-3 border-t pt-6 sm:flex-row sm:gap-5"
        >
          <p class="text-muted-foreground text-xs tracking-wide">所屬公司</p>
          <img
            src="/logos/yochaoshi.png"
            alt="有巢氏房屋 台中世界之心加盟店"
            width="258"
            height="80"
            class="h-10 w-auto sm:h-12 dark:rounded-md dark:bg-white/90 dark:px-3 dark:py-1.5"
            loading="eager"
          />
          <p class="text-muted-foreground text-center text-xs leading-relaxed">
            一品不動產 ・ 經紀人 黃永隆 113彰縣字324 ・ 營業員 陳景泰
            114登字488296
          </p>
        </div>
      </div>
    </section>

    {/* ============ SECTION 2: USP 三大價值（白色帶） ============ */}
    <section class="bg-card/50 border-border w-full border-b">
      <div class="app-layout-wide py-14 sm:py-20">
        <h2 class="mb-8 text-center text-2xl font-bold sm:text-3xl">
          為什麼找景泰
        </h2>
        <ul class="grid grid-cols-1 gap-6 sm:grid-cols-3">
          <li class="card-surface p-6">
            <div class="bg-accent/10 w-fit rounded-xl p-3">
              <IconRobot class="text-accent size-6" aria-hidden="true" />
            </div>
            <h3 class="text-foreground mt-3 text-xl font-bold">AI 工具加持</h3>
            <p class="text-muted-foreground mt-2 leading-relaxed">
              我把 591、樂屋、5168
              三大平台的曝光、修圖、回訊都自動化。同樣 24
              小時，你的物件能被更多買家看到、客戶能更快收到回覆。
            </p>
          </li>
          <li class="card-surface p-6">
            <div class="bg-accent/10 w-fit rounded-xl p-3">
              <IconSpeakerphone class="text-accent size-6" aria-hidden="true" />
            </div>
            <h3 class="text-foreground mt-3 text-xl font-bold">
              公司自媒體後盾
            </h3>
            <p class="text-muted-foreground mt-2 leading-relaxed">
              公司經營「<a
                href="/media"
                class="text-accent underline underline-offset-2 hover:no-underline">房仲大看板 BigKanBan</a
              >」自媒體 IP，IG 11K 粉、跨 4 平台 — 你的物件曝光不只一個房仲，是一整個團隊。
            </p>
          </li>
          <li class="card-surface p-6">
            <div class="bg-accent/10 w-fit rounded-xl p-3">
              <IconMapPin class="text-accent size-6" aria-hidden="true" />
            </div>
