---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import config from "@/config";
import { safeJsonLd } from "@/utils/safeJsonLd";

// 30 題長尾 FAQ — 每題對應 1 個 Google 搜尋關鍵字
// 對應分流 D 的深度文（之後文章寫好可加 link）
const faqs = [
  {
    cat: "💰 費用 / 預算",
    items: [
      {
        q: "仲介費可以議價嗎？",
        a: "可以。仲介費上限法定 6%（買方 2% + 賣方 4%）但都可議。我幫客戶議過從 6% 降到 4%、有時候賣方願意吸收買方那 2% — 看物件熱度、急售程度、議價技巧。",
      },
      {
        q: "自備款要多少？新青安 vs 一般房貸差多少？",
        a: "一般房貸通常自備 2-3 成。新青安最低自備 1 成（首次購屋族、總價 1000 萬以下、利率優惠）。新青安額度上限 1000 萬、寬限期最長 5 年、貸款年限最長 40 年。",
      },
      {
        q: "頭期款不夠怎麼辦？",
        a: "三條路：(1) 新青安申請（自備 1 成）(2) 親友信用支援（暫時周轉、需評估稅務）(3) 等待加薪 / 存到目標。不建議用信貸補頭期、利率會吃掉房貸優惠。",
      },
      {
        q: "簽約定金 / 斡旋金要付多少？",
        a: "斡旋金通常 5-10 萬（買方表達誠意、出價後付）。簽約定金通常總價 5-10%（議價成功後付）。斡旋金可全額退、定金違約會沒收。",
      },
      {
        q: "過戶要準備什麼文件？",
        a: "買方：身分證 + 印鑑證明 + 印鑑章 + 戶籍謄本 + 自備款證明。賣方：身分證 + 印鑑證明 + 印鑑章 + 權狀正本 + 印鑑章。代書統一辦理、約 1-2 個月。",
      },
    ],
  },
  {
    cat: "🏠 看屋 / 議價",
    items: [
      {
        q: "凶宅怎麼查？",
        a: "免費 4 個管道：(1) Google 搜尋「地址 凶宅」(2) 凶宅網（unluckyhouse.com）(3) 不動產說明書「重大事項」欄位（法定必載）(4) 我可以幫你查公司內部凶宅資料庫。賣方刻意隱瞞凶宅可解約 + 求償。",
      },
      {
        q: "看屋順序怎麼安排？",
        a: "3 階段 SOP：(1) 廣度看 — 同預算區跑 5-8 間建立行情感 (2) 縮窄 — 鎖定 2-3 區深度比較 (3) 鎖定 — 鎖 1-2 間反覆看（白天 / 晚上 / 雨天 / 假日）。一次看太多會疲勞、決策變差。",
      },
      {
        q: "出價跟議價有什麼不同？",
        a: "出價 = 第一次表達想買的價格（通常付斡旋金）。議價 = 仲介把你的價格傳給屋主、屋主回應後再談（可能來回 3-5 次）。出價是起點、議價是過程、最後成交價是結果。",
      },
      {
        q: "議價可以從幾折開始？",
        a: "中古屋：開價 8-9 折切入（看屋齡 / 流動性 / 賣方急售程度）。預售屋：開價 9.2-9.5 折（建商利潤空間小）。法拍：底價 + 5-10%（同行多）。最後成交價平均比開價低 5-12%。",
      },
      {
        q: "簽約要看什麼？",
        a: "5 個重點：(1) 標的物地號 / 建號 / 持分對不對 (2) 總價 / 付款條件 / 過戶日期 (3) 違約條款 (4) 履約保證 (5) 屋況現況點交。仲介會帶代書、有問題現場問清楚再簽。",
      },
    ],
  },
  {
    cat: "📐 屋況 / 屋齡",
    items: [
      {
        q: "屋齡 30 年還能買嗎？",
        a: "看 3 件事：(1) 結構（有沒有海砂、輻射、鋼筋鏽蝕）(2) 管線（自來水 + 排汙 + 電線需不需要全換、預算抓 50-150 萬）(3) 區位（蛋黃區老屋有重建價值、蛋白區老屋只有自住功能）。",
      },
      {
        q: "海砂屋 / 輻射屋怎麼測？",
        a: "海砂：取一小塊水泥送檢驗（公會約 3000 元）、看天花板有沒有大面積爆筋鏽蝕。輻射：請輻射偵測公司或自行買偵測筆（約 3000-5000 元）、看 1982-1984 年代尤其要查。",
      },
      {
        q: "漏水怎麼測？",
        a: "5 個免費招：(1) 看天花板 / 牆角有沒有水痕、油漆鼓起 (2) 摸潮濕黴味（雨天看最準）(3) 看廁所 / 廚房牆角矽利康有沒有發黑 (4) 看牆角防水漆有沒有重新漆過 (5) 雨後第 2 天去看（地下室、樓上）。",
      },
      {
        q: "違章建築能買嗎？",
        a: "可以但要評估：(1) 拆除風險（屋頂加蓋 vs 陽台外推 vs 公寓頂樓——後者最高風險）(2) 影響貸款（違建部分銀行不貸、坪數要扣）(3) 二手轉手難度高。建議違建價值算 0 來估這間房。",
      },
      {
        q: "公設比多少合理？",
        a: "看屋齡：30 年以上公寓 0-15%、20-30 年華廈 15-25%、近年大樓 30-35%、超高樓豪宅 35-45%。公設比 35% 以上要評估「實際得到坪數」、35% 表示權狀 30 坪實際只住 19.5 坪。",
      },
    ],
  },
  {
    cat: "📊 政策 / 貸款 / 稅務",
    items: [
      {
        q: "新青安貸款條件？",
        a: "首次購屋族（夫妻雙方都沒持有房屋 1 年內）、年滿 18 歲、總價 1000 萬以下、不動產位於台灣本島 + 離島。利率優惠 1.4-1.7%、寬限期 5 年、貸款年限最長 40 年。2026 年 7 月底前一定更新版本。",
      },
      {
        q: "第二戶貸款成數多少？",
        a: "2026 年 3 月起央行調整：第二戶最高 6 成（之前 5.5 成）。要看戶籍是否同戶、配偶名下房數、信用評分。提早整理還款記錄、近 6 個月信用卡正常繳清會加分。",
      },
      {
        q: "房地合一 2.0 怎麼算？",
        a: "持有 2 年內賣：45% / 持有 2-5 年：35% / 持有 5-10 年：20% / 持有 10 年以上：15%。自住豁免條件：本人 / 配偶 / 未成年子女設籍 + 居住 6 年以上 + 期間沒出租 + 沒做營業使用 → 豁免 400 萬內。",
      },
      {
        q: "房屋稅自住 vs 非自住差多少？",
        a: "自住稅率 1.2%（戶籍 + 無出租 + 限 3 戶）。非自住 1.5-3.6%（看囤房數）。地方政府逐年提高、台中 2026 起非自住第 4 戶以上 4.8%。要省稅就設籍 + 不出租。",
      },
      {
        q: "履約保證制度是什麼？",
        a: "買賣價金透過第三方銀行 / 公會專戶保管、確認過戶完成才放款給賣方。費用：總價萬分之 6（買賣方各分一半）。沒有履約保證 = 屋主拿錢跑路、買方拿不到房（每年都有案）。一定要做。",
      },
    ],
  },
  {
    cat: "🏘️ 社區 / 預售屋",
    items: [
      {
        q: "預售屋怎麼挑建商？",
        a: "5 個指標：(1) 過往作品（去現場看、住戶實際感受）(2) 財務體質（上市櫃公開財報 / 一般小建商查工商登記）(3) 履約保證機制（必須有）(4) 紅單禁令（2023 平均地權條例規定）(5) 同社區換約頻率（過高 = 信心不足）。",
      },
      {
        q: "中古屋翻新預算抓多少？",
        a: "3 級：基本（簡單水電油漆）8-15 萬/坪 ・ 中等（廚房衛浴拉皮）15-25 萬/坪 ・ 全包（連管線結構）25-40 萬/坪。30 坪老公寓全包：750-1200 萬。先看屋況再評估、別只聽設計師。",
      },
      {
        q: "老公寓加裝電梯可行嗎？",
        a: "3 條件：(1) 全體區分所有權人同意（一票不過就難）(2) 公寓基地有空間（30 坪以上比較有機會）(3) 預算（200-400 萬、分攤 4-6 樓）。台中 2024 起有都更獎勵、值得評估。",
      },
      {
        q: "雨遮算坪數嗎？",
        a: "2018/1/1 後申請建照：不算（買賣不登記）。2018/1/1 前：算。所以買中古屋看權狀「雨遮」欄位、那是不能住人但算坪的「灰色面積」。買時要扣這部分價值。",
      },
      {
        q: "車位產權 4 種怎麼分？",
        a: "(1) 平面（最值錢、權狀有獨立號碼）(2) 機械（次之、有號碼但維護費用高）(3) 坡道平面（坡道下、號碼獨立）(4) 編號車位（無權狀、住戶大會分配）。買房一定要釐清車位是哪一種。",
      },
    ],
  },
  {
    cat: "⚠️ 嫌惡設施 / 風水",
    items: [
      {
        q: "嫌惡設施有哪些？",
        a: "10 大：殯儀館 / 墓地 / 焚化爐 / 垃圾場 / 變電所 / 加油站 / 高架橋 / 鐵路 / 高壓電塔 / 八大行業。我寫過一篇 Google Map 10 大設施實測、可參考 [嫌惡設施實測文](/posts/week-04-undesirable-facilities)。",
      },
      {
        q: "離捷運站幾分鐘合理？",
        a: "步行 5 分鐘內 = 蛋黃區（價格頂規、抗跌）／ 5-10 分鐘 = CP 值最好 ／ 10-15 分鐘 = 看區位（七期 OK、其他要評估）／ 15 分鐘以上 = 對捷運加分有限。",
      },
      {
        q: "凶宅算嫌惡設施嗎？",
        a: "法律上算「重大事項」（不動產說明書必載）。買到凶宅可向賣方求償 / 解約。如果是隔壁戶才是凶宅 — 不算瑕疵、但會影響轉手價（市場通常折 10-20%）。",
      },
    ],
  },
];

// 平攤所有 items 給 FAQPage schema
const allFAQs = faqs.flatMap(c => c.items);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: allFAQs.map(item => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "首頁",
      item: new URL("/", Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "常見問題 30 題",
      item: new URL("/faq", Astro.site).href,
    },
  ],
};
---

<Layout
  title={`常見問題 30 題 | ${config.site.title}`}
  description="台中買房 / 賣房 30 個最常問的問題 — 仲介費議價、新青安、凶宅查詢、議價、嫌惡設施、稅務、車位產權，景泰一次回答完。"
  canonicalURL={new URL("/faq", Astro.site).href}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(faqSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(breadcrumbSchema)}
    />
  </Fragment>

  <Header />

  <Main
    pageTitle="常見問題 30 題"
    pageDesc="台中買賣房客戶最常問我的 30 個問題 — 一次答完、白話、實戰版。"
  >
    {/* 快速跳轉導航 */}
    <nav class="border-border bg-card mt-6 rounded-lg border p-4">
      <p class="text-muted-foreground mb-2 text-xs tracking-wide">快速跳到</p>
      <ul class="flex flex-wrap gap-x-3 gap-y-1 text-sm">
        {
          faqs.map((cat, i) => (
            <li>
              <a
                href={`#cat-${i}`}
                class="text-accent hover:underline"
              >
                {cat.cat}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    {/* FAQ 主體 */}
    <div class="mt-8 space-y-10">
      {
        faqs.map((cat, i) => (
          <section id={`cat-${i}`} class="scroll-mt-20">
            <h2 class="border-accent text-foreground border-b-2 pb-2 text-xl font-bold sm:text-2xl">
              {cat.cat}
            </h2>
            <div class="mt-4 space-y-4">
              {cat.items.map(item => (
                <details
                  class="border-border bg-card group rounded-lg border p-4 transition-colors"
                >
                  <summary class="text-foreground cursor-pointer text-base font-bold sm:text-lg">
                    {item.q}
                  </summary>
                  <p
                    class="text-foreground mt-3 leading-relaxed"
                    set:html={item.a}
                  />
                </details>
              ))}
            </div>
          </section>
        ))
      }
    </div>

    {/* 底部 CTA */}
    <section
      class="border-border mt-12 rounded-lg border border-dashed p-6 text-center"
    >
      <p class="text-foreground font-medium">
        沒看到你要問的？直接 LINE 我
      </p>
      <p class="text-muted-foreground mt-3 leading-relaxed">
        台中買賣房任何問題都可以問 — 從看屋、議價、貸款、稅務、過戶。<br />
        30 秒到 30 分鐘會回（除非在帶看或開會）。
      </p>
      <a
        href="https://line.me/ti/p/sky811117"
        class="bg-accent text-accent-foreground mt-6 inline-block rounded px-6 py-2 font-medium no-underline"
      >
        💬 LINE 私訊景泰 sky811117
      </a>
    </section>
  </Main>

  <Footer />
</Layout>
