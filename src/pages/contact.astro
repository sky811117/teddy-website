---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import ContactForm from "@/components/ContactForm.astro";
import SellForm from "@/components/SellForm.astro";
import config from "@/config";
import { safeJsonLd } from "@/utils/safeJsonLd";

// 讀 ?type= 決定要呈現「賣房表單」還是「通用詢價表單」
const type = Astro.url.searchParams.get("type") ?? "";
const isSell = type === "sell";

const pageTitle = isSell ? "賣房諮詢" : "聯絡景泰";
const pageDesc = isSell
  ? "留下屋況基本資訊 + 期望總價、24 小時內回你估價區間。也可以 LINE / 電話直接問。"
  : "LINE / 電話 / 表單三條路、看你方便。30 秒到 30 分鐘內回。";

const metaTitle = `${pageTitle} | ${config.site.title}`;
const metaDesc = isSell
  ? "台中房仲陳景泰 — 賣房委託諮詢。留下屋況 + 期望總價，24 小時內回估價區間。"
  : "台中房仲陳景泰 — 找房、賣房、換屋、投資諮詢。LINE / 電話 / 表單三條路、看你方便。30 分鐘內回覆。";

// canonicalURL 不帶 query string (?type=sell / ?type=buy 都指向同一頁，避免重複 indexing)
const canonicalURL = new URL("/contact", Astro.site).href;
const siteOrigin = new URL("/", Astro.site).href;

// ContactPage schema (Google 認得是聯絡頁、可能進 sitelinks)
const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${canonicalURL}#contactpage`,
  url: canonicalURL,
  name: metaTitle,
  description: metaDesc,
  mainEntity: { "@id": `${siteOrigin}#realestateagent` },
  // 聯絡資訊重複放在 contact page 級別 (給 Google 更明確訊號)
  potentialAction: [
    {
      "@type": "CommunicateAction",
      name: "LINE 私訊",
      target: "https://line.me/ti/p/sky811117",
    },
    {
      "@type": "CommunicateAction",
      name: "電話",
      target: "tel:+886920118756",
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "首頁",
      item: siteOrigin,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: pageTitle,
      item: canonicalURL,
    },
  ],
};
---

<Layout title={metaTitle} description={metaDesc} canonicalURL={canonicalURL}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(contactPageSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(breadcrumbSchema)}
    />
  </Fragment>

  <Header />

  <Main pageTitle={pageTitle} pageDesc={pageDesc}>
    {/* 實名 / 證號信任段 — 讓客戶確認對接的是登記在案的本人，不是名單機器人 */}
    <div
      class="border-border bg-card mt-6 flex flex-col items-center gap-4 rounded-lg border p-6 sm:flex-row sm:items-center sm:text-left"
    >
      <img
        src="/photos/teddy-avatar.jpg"
        alt="陳景泰 / 泰迪 — 台中房仲營業員"
        width="64"
        height="64"
        class="border-accent h-16 w-16 shrink-0 rounded-full border-2 object-cover"
        loading="lazy"
      />
      <div class="text-center sm:text-left">
        <p class="text-foreground text-[18px] font-bold">陳景泰</p>
        <p class="text-muted-foreground mt-1 text-[14px] leading-relaxed">
          一品不動產 有巢氏房屋台中世界之心加盟店 ／ 經紀人 黃永隆 113彰縣字324
          ・ 營業員 陳景泰 114登字488296
        </p>
        <p class="text-muted-foreground mt-2 text-[15px] leading-relaxed">
          證號可查、實名執業。你聯絡到的是本人，不是名單客服、不是 AI
          機器人；你的資料只進景泰個人 CRM，不轉賣、不外流。
        </p>
      </div>
    </div>

    {/* 三個主要聯絡方式 cards — 不分 type 都保留（賣房客戶也可能想直接 LINE） */}
    <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <a
        href="https://line.me/ti/p/sky811117"
        target="_blank"
        rel="noopener"
        class="border-border bg-card hover:border-accent hover:bg-accent/5 flex flex-col items-center rounded-lg border p-6 text-center no-underline transition-all"
      >
        <span class="text-5xl">💬</span>
        <h3 class="text-foreground mt-3 text-[18px] font-bold">LINE</h3>
        <p class="text-muted-foreground mt-1 text-[15px]">sky811117</p>
        <p class="text-muted-foreground mt-3 text-[14px] leading-relaxed">
          {isSell ? "想先聊聊再填表？這條最快" : "最快、習慣 LINE 的話直接這條"}
        </p>
      </a>

      <a
        href="tel:+886920118756"
        class="border-border bg-card hover:border-accent hover:bg-accent/5 flex flex-col items-center rounded-lg border p-6 text-center no-underline transition-all"
      >
        <span class="text-5xl">📞</span>
        <h3 class="text-foreground mt-3 text-[18px] font-bold">電話</h3>
        <p class="text-muted-foreground mt-1 text-[15px]">0920-118-756</p>
        <p class="text-muted-foreground mt-3 text-[14px] leading-relaxed">
          急的話直接撥、平日 09:00-22:00 都接
        </p>
      </a>

      <a
        href="https://instagram.com/nov__817"
        target="_blank"
        rel="noopener"
        class="border-border bg-card hover:border-accent hover:bg-accent/5 flex flex-col items-center rounded-lg border p-6 text-center no-underline transition-all"
      >
        <span class="text-5xl">📷</span>
        <h3 class="text-foreground mt-3 text-[18px] font-bold">Instagram</h3>
        <p class="text-muted-foreground mt-1 text-[15px]">@nov__817</p>
        <p class="text-muted-foreground mt-3 text-[14px] leading-relaxed">
          看日常 + 物件短影音、DM 也接
        </p>
      </a>
    </div>

    {/* 表單入口分隔 */}
    <div class="mt-12 mb-8 flex items-center gap-4">
      <div class="border-border flex-1 border-t"></div>
      <p class="text-muted-foreground text-[15px]">
        {
          isSell
            ? "或者、用下面表單給我屋況資料、24 小時內回估價"
            : "或者、不想加 LINE / 不想電話？用下面表單"
        }
      </p>
      <div class="border-border flex-1 border-t"></div>
    </div>

    {
      isSell ? (
        <SellForm
          title="想賣房？留 3 分鐘給景泰"
          subtitle="把屋況基本資訊 + 期望總價留下、24 小時內回你估價區間。資料只進景泰個人 CRM、不會給第三方。"
        />
      ) : (
        <ContactForm
          title="留你的聯絡方式、我回你"
          subtitle="長輩、企業戶、不愛即時通的人 — 用這條最舒服。Email 收件、30 分鐘內回。"
        />
      )
    }

    {/* 補充說明 */}
    <section
      class="border-border mt-10 rounded-lg border border-dashed p-6 sm:p-8"
    >
      <h3 class="text-foreground text-[18px] font-bold">
        {isSell ? "關於估價時程" : "關於回覆時間"}
      </h3>
      {
        isSell ? (
          <ul class="text-muted-foreground mt-3 space-y-2 text-[15px] leading-relaxed">
            <li>・收到表單後 24 小時內，給你估價區間（不是單一價、是合理區間）</li>
            <li>・估價依據：實價登錄成交 + 同社區在售 + 屋況加減項</li>
            <li>・想看完整估價報告：景泰會約一次 30 分鐘的免費通話 / 視訊</li>
            <li>・委託 vs 自售都可以聊、沒委託壓力</li>
          </ul>
        ) : (
          <ul class="text-muted-foreground mt-3 space-y-2 text-[15px] leading-relaxed">
            <li>・週一到週日 09:00 - 22:00：30 秒到 30 分鐘內回</li>
            <li>・22:00 後 - 翌日 09:00：隔天早上一起回</li>
            <li>・帶看 / 開會中：訊息看到會排進當日回覆順序</li>
            <li>・所有訊息都會回，沒有「回不上」的</li>
          </ul>
        )
      }
    </section>
  </Main>

  <Footer />
</Layout>
