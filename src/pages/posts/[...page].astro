---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Card from "@/components/Card.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import IconHelpCircle from "@/assets/icons/IconHelpCircle.svg";
import IconBuildingCommunity from "@/assets/icons/IconBuildingCommunity.svg";
import IconFileDescription from "@/assets/icons/IconFileDescription.svg";
import IconTool from "@/assets/icons/IconTool.svg";
import IconNotes from "@/assets/icons/IconNotes.svg";
import IconMapPin from "@/assets/icons/IconMapPin.svg";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: config.posts.perPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

// rel="prev" / "next" 給 SEO 認得分頁關係
const postsBase = new URL("/posts", Astro.site).href;
const prevURL = page.url.prev
  ? new URL(page.url.prev, Astro.site).href
  : undefined;
const nextURL = page.url.next
  ? new URL(page.url.next, Astro.site).href
  : undefined;

// 列表頂部入口卡 — emoji 全面換成 Tabler outline SVG icon
const quickLinks = [
  { Icon: IconHelpCircle, label: "常見問題 30 題", href: "/faq/" },
  {
    Icon: IconBuildingCommunity,
    label: "社區深度評測",
    href: "/tags/community-review/",
  },
  { Icon: IconFileDescription, label: "政策解析", href: "/tags/政策解析/" },
  { Icon: IconTool, label: "買房工具", href: "/tools/" },
  { Icon: IconNotes, label: "房地產詞典", href: "/tags/房地產詞典/" },
  { Icon: IconMapPin, label: "台中各區行情", href: "/areas/" },
];
---

<Layout
  title={`${t.pages.postsTitle} | ${config.site.title}`}
  description={`景泰房市筆記 — 100+ 篇台中買房賣房實戰文章。新青安、議價、嫌惡設施、政策、社區評估、區域指南。(第 ${page.currentPage}/${page.lastPage} 頁)`}
  prevURL={prevURL}
  nextURL={nextURL}
>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.pages.postsTitle} pageDesc={t.pages.postsDesc}>
    {page.currentPage === 1 && (
      <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-3">
        {quickLinks.map(({ Icon, label, href }) => (
          <a
            href={href}
            class="card-interactive flex min-h-11 items-center gap-2.5 px-4 py-3 text-sm font-medium no-underline"
          >
            <Icon class="text-accent size-5 shrink-0" aria-hidden="true" />
            <span>{label}</span>
          </a>
        ))}
      </div>
    )}
    <ul>
      {page.data.map((data, idx) => (
        <Card
          {...data}
          variant={page.currentPage === 1 && idx === 0 ? "featured" : "compact"}
          priority={idx === 0 && page.currentPage === 1}
        />
      ))}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
