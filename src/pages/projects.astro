---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import config from "@/config";
---

<Layout
  title={`整理中 | ${config.site.title}`}
  description="作品集軟性版本整理中。"
>
  <Header />

  <Main
    pageTitle="整理中…"
    pageDesc="原本這頁列了一堆內部工具 — 後來想想，把 know-how 全部攤開不是好主意。正在改寫成「對你有用的版本」。"
  >
    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
      <a
        href="/tools"
        class="border-border bg-card hover:border-accent block rounded-lg border p-6 no-underline transition-colors"
      >
        <div class="text-4xl">🧮</div>
        <h2 class="text-foreground mt-3 text-xl font-bold">給客戶的工具</h2>
        <p class="text-muted-foreground mt-2 leading-relaxed">
          買方費用試算、看屋 checklist、議價心法、台中各區行情、政府/民間公開資源整合。
        </p>
        <p class="text-accent mt-3 font-medium">→ /tools</p>
      </a>

      <a
        href="/posts"
        class="border-border bg-card hover:border-accent block rounded-lg border p-6 no-underline transition-colors"
      >
        <div class="text-4xl">📝</div>
        <h2 class="text-foreground mt-3 text-xl font-bold">房市筆記</h2>
        <p class="text-muted-foreground mt-2 leading-relaxed">
          我幫客戶踩過的雷、算過的數字 — 議價、新青安、嫌惡設施、不動產說明書。
        </p>
        <p class="text-accent mt-3 font-medium">→ /posts</p>
      </a>
    </div>

    <p class="text-muted-foreground mt-12 text-center text-sm">
      想知道更多 — <a
        href="https://line.me/ti/p/sky811117"
        class="text-accent hover:underline">LINE sky811117</a
      >。
    </p>
  </Main>

  <Footer />
</Layout>
