---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import config from "@/config";
---

<Layout
  title={`作品與工具 | ${config.site.title}`}
  description="景泰的房仲作品與工具 — 客戶工具、房市筆記、在售物件、短影音。"
  canonicalURL={new URL("/projects", Astro.site).href}
  noindex={true}
>
  <Header />

  <Main
    pageTitle="作品與工具"
    pageDesc="我做的東西，按類型分好了。"
  >
    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
      <a
        href="/tools"
        class="border-border bg-card hover:border-accent block rounded-lg border p-6 no-underline transition-colors"
      >
        <div class="text-4xl">🧮</div>
        <h2 class="text-foreground mt-3 text-xl font-bold">客戶工具</h2>
        <p class="text-muted-foreground mt-2 leading-relaxed">
          買方費用試算、看屋筆記本、各區行情速查。買房前先算清楚。
        </p>
        <p class="text-accent mt-3 font-medium">前往 →</p>
      </a>

      <a
        href="/posts"
        class="border-border bg-card hover:border-accent block rounded-lg border p-6 no-underline transition-colors"
      >
        <div class="text-4xl">📝</div>
        <h2 class="text-foreground mt-3 text-xl font-bold">房市筆記</h2>
        <p class="text-muted-foreground mt-2 leading-relaxed">
          幫客戶踩過的雷、算過的數字 — 議價、新青安、嫌惡設施。
        </p>
        <p class="text-accent mt-3 font-medium">前往 →</p>
      </a>

      <a
        href="/properties"
        class="border-border bg-card hover:border-accent block rounded-lg border p-6 no-underline transition-colors"
      >
        <div class="text-4xl">🏠</div>
        <h2 class="text-foreground mt-3 text-xl font-bold">在售物件</h2>
        <p class="text-muted-foreground mt-2 leading-relaxed">
          目前手上的委售物件，台中各區都有。
        </p>
        <p class="text-accent mt-3 font-medium">前往 →</p>
      </a>

      <a
        href="/shorts"
        class="border-border bg-card hover:border-accent block rounded-lg border p-6 no-underline transition-colors"
      >
        <div class="text-4xl">🎬</div>
        <h2 class="text-foreground mt-3 text-xl font-bold">短影音</h2>
        <p class="text-muted-foreground mt-2 leading-relaxed">
          社區實拍、看屋紀錄、台中生活日常。
        </p>
        <p class="text-accent mt-3 font-medium">前往 →</p>
      </a>
    </div>

    <p class="text-muted-foreground mt-12 text-center text-sm">
      想知道更多 — <a
        href="https://line.me/ti/p/sky811117"
        class="text-accent hover:underline">LINE sky811117</a
      >。
    </p>
  </Main>

  <Footer />
</Layout>
