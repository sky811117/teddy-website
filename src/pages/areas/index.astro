---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import config from "@/config";
import { areas } from "@/data/areas";
import { safeJsonLd } from "@/utils/safeJsonLd";

// JSON-LD: 7 區總覽頁的 ItemList
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "台中 7 區買房指南",
  itemListElement: areas.map((a, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    name: `${a.name}買房指南`,
    url: new URL(`/areas/${a.slug}`, Astro.site).href,
  })),
};

// BreadcrumbList — 給 Google 標明站內位置
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "首頁",
      item: new URL("/", Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "台中各區",
      item: new URL("/areas", Astro.site).href,
    },
  ],
};
---

<Layout
  title={`台中 7 區買房指南 | ${config.site.title}`}
  description="台中 7 大行政區（北屯 / 西屯七期 / 南屯 / 北區 / 中區 / 太平 / 大里）2026 Q1 行情、熱門社區、適合誰買、要避開什麼 — 一個房仲的實戰觀察，每區獨立深度頁。"
  canonicalURL={new URL("/areas", Astro.site).href}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(itemListSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(breadcrumbSchema)}
    />
  </Fragment>

  <Header />

  <Main
    pageTitle="台中 7 區買房指南"
    pageDesc="不同區房價走勢差很多。我把 2026 Q1 各區行情、熱門社區、適合誰買整理出來。你看哪區順手點哪區進去看深度頁。"
  >
    {/* 7 區卡片網格 */}
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        areas.map(area => (
          <a
            href={`/areas/${area.slug}`}
            class="border-border bg-card hover:border-accent group flex flex-col rounded-lg border p-6 no-underline transition-colors"
          >
            <div class="flex items-center gap-3">
              <span class="text-4xl">{area.emoji}</span>
              <h2 class="text-foreground text-xl font-bold">
                {area.name}
              </h2>
            </div>

            <p class="text-accent mt-2 font-medium">{area.headline}</p>

            <p class="text-muted-foreground mt-3 line-clamp-3 leading-relaxed">
              {area.summary}
            </p>

            <ul class="text-muted-foreground mt-4 space-y-1 text-sm">
              {area.stats.slice(0, 3).map(s => (
                <li class="flex items-baseline gap-2">
                  <span class="text-foreground/70 shrink-0">・{s.label}</span>
                  <span class="text-foreground font-medium">{s.value}</span>
                  {s.trend && <span class="text-xs">{s.trend}</span>}
                </li>
              ))}
            </ul>

            <div class="text-accent mt-auto pt-4 text-sm font-medium group-hover:underline">
              看 {area.shortName}深度頁 →
            </div>
          </a>
        ))
      }
    </div>

    {/* 底部 CTA */}
    <section
      class="border-border mt-12 rounded-lg border border-dashed p-6 text-center"
    >
      <p class="text-foreground font-medium">想看其他區？</p>
      <p class="text-muted-foreground mt-3 leading-relaxed">
        東區 / 南區 / 西區 / 烏日 / 大雅 / 豐原 / 海線（梧棲 / 沙鹿 / 龍井 / 清水）
        — 整個台中我都跑。LINE 我說你想看哪、我給你最近 3 個月當區行情 + 推薦物件。
      </p>
      <a
        href="https://line.me/ti/p/sky811117"
        class="bg-accent text-accent-foreground mt-6 inline-block rounded px-6 py-2 font-medium no-underline"
      >
        LINE sky811117 問景泰
      </a>
      <p class="text-muted-foreground mt-4 text-xs">
        一品不動產 有巢氏房屋 台中世界之心加盟店<br />
        經紀人 黃永隆 113彰縣字324 ・ 營業員 陳景泰 114登字488296
      </p>
    </section>
  </Main>

  <Footer />
</Layout>
