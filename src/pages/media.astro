---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import config from "@/config";

const personalAccounts = [
  {
    platform: "Instagram",
    handle: "@nov__817",
    role: "主帳號 · 房仲日常",
    desc: "我的主 IG 帳號。最新物件、看屋日常、房市觀察都在這。想知道我每天在跑什麼，這裡最直接。",
    url: "https://www.instagram.com/nov__817/",
    icon: "📷",
    color: "from-pink-500/20 to-purple-500/20",
  },
  {
    platform: "Facebook",
    handle: "陳景泰",
    role: "個人主頁",
    desc: "日常 + 房仲業務分享，看我每天在跑什麼物件、做什麼決定。長文比較完整。",
    url: "https://www.facebook.com/profile.php?id=61575492127872",
    icon: "📘",
    color: "from-blue-600/20 to-blue-400/20",
  },
  {
    platform: "YouTube",
    handle: "@泰迪001",
    role: "影片頻道",
    desc: "房屋開箱、看屋現場、講解小知識。比短影音更完整，適合一邊吃飯一邊看。",
    url: "https://www.youtube.com/@%E6%B3%B0%E8%BF%AA001",
    icon: "📺",
    color: "from-red-500/20 to-red-300/20",
  },
  {
    platform: "TikTok",
    handle: "@sky811117",
    role: "短影音",
    desc: "30 秒看完一間房 — 一鏡到底、快剪、看屋現場最快感受。台中房市快訊也在這。",
    url: "https://www.tiktok.com/@sky811117",
    icon: "🎬",
    color: "from-pink-500/20 to-purple-500/20",
  },
  {
    platform: "LINE",
    handle: "sky811117",
    role: "直接私訊",
    desc: "上面平台都看完還想問？直接 LINE 我。通常 30 秒到 30 分鐘會回（除非帶看或開會）。",
    url: "https://line.me/ti/p/sky811117",
    icon: "💬",
    color: "from-green-500/20 to-emerald-500/20",
  },
];

const accounts = [
  {
    platform: "Instagram",
    handle: "@bigkanban",
    role: "主帳號",
    desc: "BOSS｜房仲大看板的主 IG，11K 追蹤。發物件開箱、看屋小知識、房市快訊。台中買賣房客人會在這找到我們。",
    url: "https://instagram.com/bigkanban",
    icon: "📷",
    color: "from-pink-500/20 to-purple-500/20",
  },
  {
    platform: "Instagram",
    handle: "@bigkanban.boss",
    role: "BOSS 個人帳",
    desc: "BOSS 本尊的個人帳號 — 20 年房仲、法拍 + 銀行貸款專家。日常房地產分享，比較個人風格。",
    url: "https://instagram.com/bigkanban.boss",
    icon: "👔",
    color: "from-blue-500/20 to-cyan-500/20",
  },
  {
    platform: "TikTok",
    handle: "@bigkanban2.0",
    role: "短影音主帳",
    desc: "房屋開箱短影音、看屋現場、講解小知識。30 秒一鏡到底，最快了解一間房的格局氛圍。",
    url: "https://www.tiktok.com/@bigkanban2.0",
    icon: "🎬",
    color: "from-red-500/20 to-orange-500/20",
  },
  {
    platform: "Facebook",
    handle: "BigKanBan 粉專",
    role: "深度長文+物件",
    desc: "適合看長篇分析、社區深度報導、賣方故事。比 IG/TT 內容更完整。",
    url: "https://www.facebook.com/bigkanban",
    icon: "📘",
    color: "from-blue-600/20 to-blue-400/20",
  },
];
---

<Layout
  title={`找景泰 + 房仲大看板 | ${config.site.title}`}
  description="景泰個人 4 平台 + 公司房仲大看板 BigKanBan 4 帳號 — 8 個觸點都找得到我。"
  canonicalURL={new URL("/media", Astro.site).href}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "@id": `${new URL("/media", Astro.site).href}#collectionpage`,
        name: "景泰 + 房仲大看板 8 個觸點",
        description: "景泰個人 4 平台 (IG/FB/YouTube/TikTok) + 公司房仲大看板 BigKanBan 4 帳號",
        mainEntity: { "@id": `${new URL("/", Astro.site).href}#realestateagent` },
      })}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "首頁", item: new URL("/", Astro.site).href },
          { "@type": "ListItem", position: 2, name: "找景泰", item: new URL("/media", Astro.site).href },
        ],
      })}
    />
  </Fragment>
  <Header />

  <Main
    pageTitle="找景泰 + 大看板"
    pageDesc="你看哪個平台順手就追哪個。景泰個人 4 個 + 公司房仲大看板 4 個 — 8 個觸點都會看到我們在跑什麼。"
  >
    {/* ===== 景泰個人 4 帳號 ===== */}
    <section class="mt-8">
      <h2 class="text-foreground border-accent border-b-2 pb-2 text-2xl font-bold">
        👤 景泰個人
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-6">
        {
          personalAccounts.map(acc => (
            <a
              href={acc.url}
              target="_blank"
              rel="noopener"
              class:list={[
                "border-border bg-card hover:border-accent block rounded-lg border p-6 no-underline transition-colors",
                `bg-gradient-to-br ${acc.color}`,
              ]}
            >
              <div class="flex items-start gap-4">
                <div class="text-5xl">{acc.icon}</div>
                <div class="flex-1">
                  <div class="flex flex-wrap items-baseline gap-2">
                    <h3 class="text-foreground text-xl font-bold sm:text-2xl">
                      {acc.platform}
                    </h3>
                    <span class="text-accent text-lg">{acc.handle}</span>
                    <span class="bg-muted text-muted-foreground rounded px-2 py-0.5 text-xs">
                      {acc.role}
                    </span>
                  </div>
                  <p class="text-foreground mt-3 leading-relaxed">{acc.desc}</p>
                  <p class="text-accent mt-3 font-medium">→ 開啟 / 追蹤</p>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    {/* ===== 公司 BigKanBan 4 帳號 ===== */}
    <section class="mt-12">
      <div class="border-accent flex flex-wrap items-center gap-3 border-b-2 pb-3">
        <img
          src="/logos/bigkanban.png"
          alt="房仲大看板 BigKanBan"
          class="h-12 w-auto sm:h-14"
          loading="lazy"
        />
        <h2 class="text-foreground text-xl font-bold sm:text-2xl">
          公司房仲大看板 4 個帳號
        </h2>
      </div>
      <p class="text-muted-foreground mt-3 leading-relaxed">
        我所在公司經營的房仲業 KOL IP — IG 主帳 11K 粉、跨 4 平台、每天 50+
        客戶詢問、單社區成交破百筆。<strong class="text-foreground"
          >你的物件曝光，不只我一個人在做，是整套團隊。</strong
        >
      </p>
      <div class="mt-6 grid grid-cols-1 gap-6">
        {
          accounts.map(acc => (
          <a
            href={acc.url}
            target="_blank"
            rel="noopener"
            class:list={[
              "border-border bg-card hover:border-accent block rounded-lg border p-6 no-underline transition-colors",
              `bg-gradient-to-br ${acc.color}`,
            ]}
          >
            <div class="flex items-start gap-4">
              <div class="text-5xl">{acc.icon}</div>
              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-2">
                  <h2 class="text-foreground text-xl font-bold sm:text-2xl">
                    {acc.platform}
                  </h2>
                  <span class="text-accent text-lg">{acc.handle}</span>
                  <span class="bg-muted text-muted-foreground rounded px-2 py-0.5 text-xs">
                    {acc.role}
                  </span>
                </div>
                <p class="text-foreground mt-3 leading-relaxed">{acc.desc}</p>
                <p class="text-accent mt-3 font-medium">→ 開啟 / 追蹤</p>
              </div>
            </div>
          </a>
        ))
      }
    </section>

    <section
      class="border-border mt-12 rounded-lg border border-dashed p-6 text-center"
    >
      <p class="text-foreground font-medium">為什麼這對你有意義？</p>
      <p class="text-muted-foreground mt-3 leading-relaxed">
        賣方角度：你的物件不只刊到 591 / 樂屋 / 5168，<strong class="text-foreground"
          >還會透過 BigKanBan 4 帳號跨平台曝光</strong
        >，被更多買家看到。<br />
        買方角度：你看到的不只是我一個房仲的眼界 — <strong class="text-foreground"
          >是整個公司 20 年經驗 + AI 工具 + KOL 流量</strong
        >的累積。
      </p>
      <a
        href="https://line.me/ti/p/sky811117"
        class="bg-accent text-accent-foreground mt-6 inline-block rounded px-6 py-2 font-medium no-underline"
      >
        LINE 私訊景泰 sky811117
      </a>
    </section>
  </Main>

  <Footer />
</Layout>
