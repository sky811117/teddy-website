<script
  is:inline
  define:vars={{
    photos: property.data.photos,
    title: property.data.title,
    total: property.data.photos.length,
  }}
>
  (function () {
    if (!photos || photos.length === 0) return;

    const gallery = document.querySelector("[data-gallery]");
    if (!gallery) return;

    const mainImg = gallery.querySelector("[data-gallery-main]");
    const mainBtn = gallery.querySelector("[data-gallery-main-btn]");
    const counter = gallery.querySelector("[data-gallery-counter]");
    const thumbBtns = gallery.querySelectorAll("[data-gallery-index]");

    const dialog = document.querySelector("[data-gallery-lightbox]");
    const lbImg = dialog && dialog.querySelector("[data-gallery-lightbox-img]");
    const lbCounter = dialog && dialog.querySelector("[data-gallery-lightbox-counter]");
    const closeBtn = dialog && dialog.querySelector("[data-gallery-close]");
    const prevBtn = dialog && dialog.querySelector("[data-gallery-prev]");
    const nextBtn = dialog && dialog.querySelector("[data-gallery-next]");

    let current = 0;

    function setIndex(i) {
      current = ((i % total) + total) % total;
      const src = photos[current];
      const label = `${title}（第 ${current + 1} 張，共 ${total} 張）`;
      if (mainImg) {
        mainImg.src = src;
        mainImg.alt = label;
      }
      if (counter) counter.textContent = `${current + 1} / ${total}`;
      if (lbImg) {
        lbImg.src = src;
        lbImg.alt = label;
      }
      if (lbCounter) lbCounter.textContent = `${current + 1} / ${total}`;
      thumbBtns.forEach((b, idx) => {
        const active = idx === current;
        b.classList.toggle("border-accent", active);
        b.classList.toggle("opacity-100", active);
        b.classList.toggle("border-transparent", !active);
        b.classList.toggle("opacity-60", !active);
      });
      // scroll thumb into view
      const activeThumb = thumbBtns[current];
      if (activeThumb && activeThumb.scrollIntoView) {
        activeThumb.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
          inline: "center",
        });
      }
    }

    function openLightbox() {
      if (!dialog) return;
      if (typeof dialog.showModal === "function") {
        dialog.showModal();
      } else {
        dialog.setAttribute("open", "");
      }
      document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
      if (!dialog) return;
      if (typeof dialog.close === "function") {
        dialog.close();
      } else {
        dialog.removeAttribute("open");
      }
      document.body.style.overflow = "";
    }

    if (mainBtn) mainBtn.addEventListener("click", openLightbox);
    thumbBtns.forEach(b => {
      b.addEventListener("click", () => {
        const i = parseInt(b.dataset.galleryIndex || "0", 10);
        setIndex(i);
      });
    });

    // 桌面 collage：點任一格 → 跳到該張並開 lightbox（沿用既有邏輯）
    gallery.querySelectorAll("[data-collage-index]").forEach(b => {
      b.addEventListener("click", () => {
        setIndex(parseInt(b.dataset.collageIndex || "0", 10));
        openLightbox();
      });
    });
    if (closeBtn) closeBtn.addEventListener("click", closeLightbox);
    if (prevBtn) prevBtn.addEventListener("click", () => setIndex(current - 1));
    if (nextBtn) nextBtn.addEventListener("click", () => setIndex(current + 1));

    // 點 backdrop 關閉
    if (dialog) {
      dialog.addEventListener("click", e => {
        if (e.target === dialog) closeLightbox();
      });
      dialog.addEventListener("close", () => {
        document.body.style.overflow = "";
      });
    }

    // 鍵盤導覽（lightbox 開啟時）
    document.addEventListener("keydown", e => {
      if (!dialog || !dialog.open) return;
      if (e.key === "ArrowLeft") {
        e.preventDefault();
        setIndex(current - 1);
      } else if (e.key === "ArrowRight") {
        e.preventDefault();
        setIndex(current + 1);
      }
    });
  })();
</script>

<script is:inline>
  // 桌面版 sticky CTA bar 滑入/滑出：滾過 600px 出現、靠近 ContactForm 時收回
  (function () {
    const sticky = document.querySelector("[data-property-sticky]");
    if (!sticky) return;
    const form = document.getElementById("contact-form-section");

    let raf = null;
    function update() {
      raf = null;
      const scrolled = window.scrollY > 600;
      let nearForm = false;
      if (form) {
        const rect = form.getBoundingClientRect();
        // ContactForm 進到視窗 60% 以上 → 隱藏 sticky（已經看到表單就不用 CTA bar）
        nearForm = rect.top < window.innerHeight * 0.6;
      }
      const show = scrolled && !nearForm;
      sticky.classList.toggle("translate-y-full", !show);
      sticky.setAttribute("aria-hidden", show ? "false" : "true");
    }
    function onScroll() {
      if (raf === null) raf = requestAnimationFrame(update);
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  })();
</script>

<script is:inline>
  // 內文去重：markdown body 由 properties-sync 批次產出，固定帶「## 物件規格」
  // bullet 段落（與上方規格卡重複）+「> 委編：…」blockquote（已改成標題下 badge）。
  // .md 內容不能動（sync 會整批覆寫），改在 client 端把這兩段從渲染移除；
  // 無 JS 時 fallback 維持完整內文，資訊不會缺。
  (function () {
    const prose = document.querySelector("[data-property-content]");
    if (!prose) return;
    prose.querySelectorAll("h2").forEach(h => {
      if ((h.textContent || "").trim() !== "物件規格") return;
      let node = h.nextElementSibling;
      h.remove();
      // 連同其後內容（到下一個標題 / hr 為止）一起移除，證號段落在 hr 後不受影響
      while (node && !/^(H[1-6]|HR)$/.test(node.tagName)) {
        const next = node.nextElementSibling;
        node.remove();
        node = next;
      }
    });
    prose.querySelectorAll("blockquote").forEach(bq => {
      if ((bq.textContent || "").includes("委編：")) bq.remove();
    });
  })();
</script>

<script
  is:inline
  define:vars={{
    quickCode: property.data.listingCode ?? "",
    quickTitle: property.data.title,
  }}
>
  // 表單瘦身（漸進增強）：ContactForm 是全站共用元件不能動，改在本頁把
  // Email / 我想 / 預算 / 區域偏好 收進「進階需求（選填）」<details>，
  // 預設只露 姓名 / 手機 / 訊息；並在表單頂部加 3 顆 quick chips 一鍵覆寫訊息。
  // 無 JS 時 fallback 維持完整表單，功能不會缺。
  (function () {
    const form = document.querySelector("[data-contact-form]");
    if (!form) return;
    const msgInput = form.querySelector("[name='訊息']");
    const msgWrap = msgInput ? msgInput.closest("div") : null;

    // --- 進階需求 <details>：搬 Email / 我想+預算 grid / 區域偏好 ---
    const emailEl = document.getElementById("cf-email");
    const emailWrap = emailEl ? emailEl.closest("div") : null;
    const intentEl = document.getElementById("cf-intent");
    const intentGrid = intentEl ? intentEl.closest(".grid") : null;
    const areaSummary = form.querySelector("[data-area-summary]");
    const areaDetails = areaSummary ? areaSummary.closest("details") : null;
    const areaBlock = areaDetails ? areaDetails.parentElement : null;

    if (msgWrap && (emailWrap || intentGrid || areaBlock)) {
      const adv = document.createElement("details");
      adv.className = "border-border bg-background rounded-md border";
      const summary = document.createElement("summary");
      summary.className =
        "text-muted-foreground cursor-pointer px-4 py-3 text-[15px] select-none";
      summary.textContent = "進階需求（選填）▾";
      const body = document.createElement("div");
      body.className = "space-y-5 p-4 pt-2";
      adv.append(summary, body);
      msgWrap.after(adv);
      [emailWrap, intentGrid, areaBlock].forEach(el => {
        if (el) body.appendChild(el);
      });
    }

    // --- quick chips：點了覆寫訊息（物件編號 hidden 欄位另有預填、不受影響） ---
    if (msgInput) {
      const chips = document.createElement("div");
      chips.className = "flex flex-wrap gap-2";
      ["想約看屋", "想問貸款", "想要實照"].forEach(text => {
        const b = document.createElement("button");
        b.type = "button";
        b.className =
          "border-border bg-background text-foreground hover:border-accent hover:text-accent cursor-pointer rounded-full border px-3 py-1.5 text-sm transition-colors";
        b.textContent = text;
        b.addEventListener("click", () => {
          const ref = quickCode
            ? "物件 " + quickCode + (quickTitle ? "（" + quickTitle + "）" : "")
            : "這個物件";
          msgInput.value = text + "：" + ref;
          msgInput.dispatchEvent(new Event("input", { bubbles: true }));
          msgInput.focus();
        });
        chips.appendChild(b);
      });
      form.insertBefore(chips, form.firstElementChild);
    }
  })();
</script>
