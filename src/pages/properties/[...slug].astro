---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ContactForm from "@/components/ContactForm.astro";
import config from "@/config";
import { safeJsonLd } from "@/utils/safeJsonLd";
import { resolveDefaultOgImagePath } from "@/utils/resolveDefaultOgImagePath";
import { cleanStreetArea } from "@/utils/cleanStreetArea";
import IconMapPin from "@/assets/icons/IconMapPin.svg";
import IconBuildingCommunity from "@/assets/icons/IconBuildingCommunity.svg";
import IconPhone from "@/assets/icons/IconPhone.svg";
import IconClipboardList from "@/assets/icons/IconClipboardList.svg";
import IconLine from "@/assets/icons/socials/line.svg";

// 縣市對照（與 index.astro 同步）
const TAICHUNG = new Set([
  "北屯區","西屯區","南屯區","北區","南區","東區","西區","中區","太平區","大里區",
  "霧峰區","烏日區","大肚區","沙鹿區","梧棲區","清水區","大甲區","外埔區","大安區",
  "龍井區","潭子區","大雅區","神岡區","豐原區","后里區","東勢區","和平區","新社區","石岡區",
]);
const NANTOU = new Set(["南投市","草屯鎮","埔里鎮","竹山鎮","集集鎮","名間鄉","中寮鄉","水里鄉","魚池鄉","國姓鄉","信義鄉","仁愛鄉","鹿谷鄉"]);
const CHANGHUA = new Set(["彰化市","和美鎮","田中鎮","二林鎮","北斗鎮","員林市","溪湖鎮","鹿港鎮","大村鄉","田尾鄉","秀水鄉","花壇鄉","芬園鄉","福興鄉","線西鄉","伸港鄉","埔鹽鄉","埔心鄉","永靖鄉","社頭鄉","二水鄉","竹塘鄉","溪州鄉","大城鄉","芳苑鄉"]);
const MIAOLI = new Set(["苗栗市","竹南鎮","頭份市","卓蘭鎮","苑裡鎮","通霄鎮","後龍鎮","獅潭鄉","泰安鄉","銅鑼鄉","三義鄉","西湖鄉","造橋鄉","公館鄉","三灣鄉","南庄鄉","頭屋鄉"]);

function getCounty(d: string): string {
  if (TAICHUNG.has(d)) return "台中市";
  if (NANTOU.has(d)) return "南投縣";
  if (CHANGHUA.has(d)) return "彰化縣";
  if (MIAOLI.has(d)) return "苗栗縣";
  for (const [p, c] of [["南投","南投縣"],["彰化","彰化縣"],["苗栗","苗栗縣"],["台中","台中市"],["臺中","台中市"]] as const) {
    if (d.startsWith(p)) return c;
  }
  return "其他";
}

export async function getStaticPaths() {
  const properties = await getCollection("properties", ({ data }) => data.status === "active");
  return properties.map(property => ({
    params: { slug: property.id },
    props: { property, properties },
  }));
}

type Props = {
  property: CollectionEntry<"properties">;
  properties: CollectionEntry<"properties">[];
};

const { property, properties } = Astro.props;
const { Content } = await render(property);

const formatPrice = (price: number) => {
  if (price >= 10000) return `${(price / 10000).toFixed(2)} 億`;
  return `${price.toLocaleString()} 萬`;
};

// 新上架 / 降價 判斷
const NEW_DAYS = 7;
const isNew =
  property.data.pubDatetime &&
  (Date.now() - property.data.pubDatetime.getTime()) / 86400000 <= NEW_DAYS;
const dropPct =
  property.data.lastPrice && property.data.lastPrice > property.data.totalPrice
    ? Math.round(((property.data.lastPrice - property.data.totalPrice) / property.data.lastPrice) * 100)
    : null;

// badge 防通膨（與列表頁同步）：pubDatetime 是批次同步日（properties-sync 整批重寫），
// 若全站超過 30% 物件都判定為「新上架」→ 整批不顯示新上架 badge。
// 等 properties-sync 補 firstSeen 欄位後才能恢復精準判定。
const NEW_BADGE_MAX_RATIO = 0.3;
const siteNewCount = properties.filter(
  p =>
    p.data.pubDatetime &&
    (Date.now() - p.data.pubDatetime.getTime()) / 86400000 <= NEW_DAYS
).length;
const showNewBadge =
  properties.length > 0 &&
  siteNewCount / properties.length <= NEW_BADGE_MAX_RATIO;

// 位置去重：streetArea 帶行政區前綴時去掉（標題下 / sticky bar 共用）
const streetAreaClean = cleanStreetArea(
  property.data.streetArea,
  property.data.district
);

// 委編 / 專任 badge：
// - 完整委編（含 UT/UG/HG 前綴）藏在 markdown body 的「> 委編：XXX」blockquote，
//   build-time 從 body 撈出來，fallback frontmatter listingCode
// - 「本店專任」依標題是否含「專任」判定
const bodyCodeMatch = property.body?.match(/委編：([A-Z0-9]+)/);
const fullListingCode = bodyCodeMatch?.[1] ?? property.data.listingCode;
const isExclusive = property.data.title.includes("專任");

// 類型（給規格卡用）：優先撈 markdown body 的「**類型**：XXX」，最準
const bodyTypeMatch = property.body?.match(/\*\*類型\*\*：\s*([^\n\r]+)/);
const propertyType = bodyTypeMatch?.[1]?.trim();

// 月付試算（build-time 靜態值）：8 成 30 年本利均攤、利率 2.306%（/tools 每月底更新）
const LOAN_RATIO = 0.8;
const LOAN_YEARS = 30;
const LOAN_RATE = 0.02306;
const monthlyRate = LOAN_RATE / 12;
const totalMonths = LOAN_YEARS * 12;
const loanPrincipal = property.data.totalPrice * LOAN_RATIO; // 單位：萬
const monthlyPayment =
  (loanPrincipal * monthlyRate * Math.pow(1 + monthlyRate, totalMonths)) /
  (Math.pow(1 + monthlyRate, totalMonths) - 1); // 單位：萬/月
const monthlyPaymentText = monthlyPayment.toFixed(1);

// 照片 collage（桌面、照片 ≥3 張才啟用）：主圖 + 副圖最多 4 張
const photos = property.data.photos;
const useCollage = photos.length >= 3;
const collageSide = photos.slice(1, 5);
// 沒露出的張數（疊在最後一格的「+N 張」遮罩）
const collageHiddenCount = photos.length - 1 - collageSide.length;

// 找同縣市其他物件（最多 6 筆）
const thisCounty = getCounty(property.data.district);
const sameCounty = properties
  .filter(p => p.id !== property.id && getCounty(p.data.district) === thisCounty)
  // 有照片優先 > 同區域 > 價格相近
  .sort((a, b) => {
    const coverDiff = (a.data.coverImage ? 0 : 1) - (b.data.coverImage ? 0 : 1);
    if (coverDiff !== 0) return coverDiff;
    const aSameDistrict = a.data.district === property.data.district ? 0 : 1;
    const bSameDistrict = b.data.district === property.data.district ? 0 : 1;
    if (aSameDistrict !== bSameDistrict) return aSameDistrict - bSameDistrict;
    return Math.abs(a.data.totalPrice - property.data.totalPrice) - Math.abs(b.data.totalPrice - property.data.totalPrice);
  })
  .slice(0, 6);

// ============ SEO + JSON-LD ============
const canonicalURL = new URL(`/properties/${property.id}`, Astro.site).href;

// description: 優先 frontmatter description，沒有則組合基本資訊
// smartTruncate: 在 max chars 內找最後一個中文句末標點 (。！？) 切斷，避免斷句中間
function smartTruncate(s: string, max: number): string {
  if (s.length <= max) return s;
  const head = s.slice(0, max);
  // 嘗試在 max 範圍找最後一個句末標點
  const cutPoints = [...head.matchAll(/[。！？\?\!\.]/g)];
  if (cutPoints.length > 0) {
    const last = cutPoints[cutPoints.length - 1];
    // 句末標點位置 >= max*0.6 才採用，否則太短
    if (last.index !== undefined && last.index >= max * 0.6) {
      return head.slice(0, last.index + 1);
    }
  }
  // fallback: 找逗號 / 全形空白 / 換行
  const softCut = [...head.matchAll(/[，、,;\s]/g)];
  if (softCut.length > 0) {
    const last = softCut[softCut.length - 1];
    if (last.index !== undefined && last.index >= max * 0.7) {
      return head.slice(0, last.index) + "…";
    }
  }
  return head + "…";
}

const seoDescription = property.data.description
  ? smartTruncate(property.data.description, 160)
  : `${property.data.district} ${property.data.layout} ${property.data.area}坪，總價 ${formatPrice(property.data.totalPrice)}。台中房仲景泰實價整理。`;

// ogImage: 用物件首圖（絕對路徑），fallback 到全站 default OG
const coverImageSrc = property.data.coverImage
  ? typeof property.data.coverImage === "string"
    ? property.data.coverImage
    : property.data.coverImage.src
  : property.data.photos[0] ?? null;
const ogImagePath = coverImageSrc
  ? new URL(coverImageSrc, Astro.site).href
  : new URL(resolveDefaultOgImagePath(config), Astro.site).href;

// 從 layout 抓房數（給 numberOfRooms）
const roomsMatch = property.data.layout?.match(/(\d+)\s*房/);
const numberOfRooms = roomsMatch ? parseInt(roomsMatch[1], 10) : undefined;

// 把「萬」轉成「元」(Google offers 用 TWD 標準幣別單位)
const priceInNTD = property.data.totalPrice * 10000;

// priceValidUntil: 預設廣告 90 天後 (跟物件刊登週期對齊)
const priceValidUntil = new Date(
  Date.now() + 90 * 24 * 60 * 60 * 1000
).toISOString().slice(0, 10);

// 物件類型 → schema.org type 對應
function getSchemaType(p: typeof property): string {
  // 對中文 .toLowerCase() 無作用，但對混合英文標題仍有用
  const t = (p.data.title + " " + (p.data.layout || "")).toLowerCase();
  if (t.includes("透天") || t.includes("別墅")) return "SingleFamilyResidence";
  if (t.includes("公寓")) return "Apartment";
  if (t.includes("套房")) return "Apartment";
  if (t.includes("店面") || t.includes("商辦") || t.includes("廠房"))
    return "LocalBusiness";
  if (t.includes("土地") || t.includes("農地") || t.includes("建地"))
    return "Place";
  // 預設大樓/華廈
  return "Apartment";
}
const schemaType = getSchemaType(property);

// 證號前綴防雙重 (frontmatter 若已含 "經紀人 X" / "營業員 X" 就不加)
function withPrefix(prefix: string, value: string): string {
  return value.startsWith(prefix) ? value : `${prefix}${value}`;
}

// 圖片 array: 至多 6 張避免 JSON-LD payload 過大
const MAX_SCHEMA_IMAGES = 6;
const schemaImages = property.data.photos.length > 0
  ? property.data.photos
      .slice(0, MAX_SCHEMA_IMAGES)
      .map(p => new URL(p, Astro.site).href)
  : [ogImagePath];

// 主 schema: RealEstateListing 風格（用 schema.org 標準 Place + Product/Offer 雙標）
const propertySchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: property.data.title,
  description: seoDescription,
  image: schemaImages,
  category: "Real Estate",
  brand: {
    "@type": "Organization",
    name: "有巢氏房屋 台中世界之心加盟店",
  },
  offers: {
    "@type": "Offer",
    price: priceInNTD,
    priceCurrency: "TWD",
    availability:
      property.data.status === "active"
        ? "https://schema.org/InStock"
        : "https://schema.org/OutOfStock",
    url: canonicalURL,
    priceValidUntil,
    seller: {
      "@type": "RealEstateAgent",
      name: "陳景泰",
      telephone: "+886-920-118-756",
      email: "a0920118756@gmail.com",
      hasCredential: [
        withPrefix("經紀人 ", property.data.brokerLicense),
        withPrefix("營業員 ", property.data.agentLicense),
      ],
    },
  },
  // 額外 Residence 屬性（Google 認 additionalProperty）
  additionalProperty: [
    {
      "@type": "PropertyValue",
      name: "格局",
      value: property.data.layout,
    },
    {
      "@type": "PropertyValue",
      name: "權狀坪數",
      value: `${property.data.area} 坪`,
    },
    ...(property.data.age !== undefined
      ? [{ "@type": "PropertyValue", name: "屋齡", value: `${property.data.age} 年` }]
      : []),
    ...(property.data.floor
      ? [{ "@type": "PropertyValue", name: "樓層", value: property.data.floor }]
      : []),
    ...(property.data.parking
      ? [{ "@type": "PropertyValue", name: "車位", value: property.data.parking }]
      : []),
    ...(numberOfRooms
      ? [{ "@type": "PropertyValue", name: "房數", value: numberOfRooms }]
      : []),
  ],
};

// 第二層：Place schema 標地址（給 Google Maps + Local Search）
// addressRegion 只在 county 為已知縣市時輸出 (避免出現 "其他" 怪詞)
const placeSchema = {
  "@context": "https://schema.org",
  "@type": schemaType,
  name: property.data.title,
  address: {
    "@type": "PostalAddress",
    addressLocality: property.data.district,
    ...(thisCounty !== "其他" ? { addressRegion: thisCounty } : {}),
    addressCountry: "TW",
    ...(property.data.streetArea ? { streetAddress: property.data.streetArea } : {}),
  },
  ...(property.data.area
    ? {
        floorSize: {
          "@type": "QuantitativeValue",
          value: property.data.area,
          unitText: "坪",
        },
      }
    : {}),
  ...(numberOfRooms ? { numberOfRooms } : {}),
  // yearBuilt 故意不輸出 — age 是 build-time 快照、跨年會 stale；schema 沒設 yearBuilt 比 stale 好
};

// Breadcrumb
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "首頁",
      item: new URL("/", Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "在售物件",
      item: new URL("/properties", Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: property.data.title,
      item: canonicalURL,
    },
  ],
};
---

<Layout
  title={`${property.data.title} | ${config.site.title}`}
  description={seoDescription}
  ogImage={ogImagePath}
  canonicalURL={canonicalURL}
  showFloatingCTA={false}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(propertySchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(placeSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(breadcrumbSchema)}
    />
  </Fragment>

  <Header />

  {/* 桌面版 sticky CTA bar — 滾動超過 600px 才出現，常駐在視窗底部直到看完 */}
  <div
    data-property-sticky
    class="border-border bg-card/95 fixed inset-x-0 bottom-0 z-30 hidden translate-y-full border-t shadow-lg backdrop-blur transition-transform duration-300 sm:block"
    aria-hidden="true"
  >
    <div class="app-layout max-w-app flex flex-wrap items-center justify-between gap-4 py-3">
      <div class="min-w-0 flex-1">
        <p class="text-foreground line-clamp-1 text-sm font-semibold">
          {property.data.title}
        </p>
        <p class="text-muted-foreground flex items-center gap-1 text-xs">
          <IconMapPin class="size-3.5 shrink-0" aria-hidden="true" />
          <span class="line-clamp-1">
            {property.data.district}
            {streetAreaClean ? `・${streetAreaClean}` : ""}
            ・{property.data.layout} ・{property.data.area} 坪
          </span>
        </p>
      </div>
      <div class="text-accent shrink-0 text-xl font-bold sm:text-2xl">
        {formatPrice(property.data.totalPrice)}
      </div>
      <div class="flex shrink-0 items-center gap-2">
        <a href="#contact-form-section" class="btn-outline text-sm">
          <IconClipboardList class="size-4" aria-hidden="true" />
          詢問
        </a>
        <a href="tel:+886920118756" class="btn-outline text-sm">
          <IconPhone class="size-4" aria-hidden="true" />
          撥打
        </a>
        <a href="https://line.me/ti/p/sky811117" class="btn-line text-sm">
          <IconLine class="size-4" aria-hidden="true" />
          LINE 景泰
        </a>
      </div>
    </div>
  </div>

  {/* 手機版常駐底部 CTA bar — 細價格列 + 三鍵、純 CSS、只在手機出現 */}
  <div class="border-border bg-card/95 fixed inset-x-0 bottom-0 z-40 border-t shadow-lg backdrop-blur sm:hidden" data-property-mobile-cta>
    <div class="border-border flex h-8 min-w-0 items-center justify-between gap-2 border-b px-3">
      <p class="text-foreground line-clamp-1 min-w-0 flex-1 text-xs">{property.data.title}</p>
      <span class="text-accent shrink-0 text-base font-bold">{formatPrice(property.data.totalPrice)}</span>
    </div>
    <div class="grid grid-cols-3">
      <a href="tel:+886920118756" class="text-accent flex min-h-11 flex-col items-center justify-center gap-0.5 py-2.5 text-xs font-medium no-underline"><IconPhone class="size-5" aria-hidden="true" />撥電話</a>
      <a href="https://line.me/ti/p/sky811117" class="bg-line flex min-h-11 flex-col items-center justify-center gap-0.5 py-2.5 text-xs font-medium text-white no-underline"><IconLine class="size-5" aria-hidden="true" />LINE 景泰</a>
      <a href="#contact-form-section" class="text-accent flex min-h-11 flex-col items-center justify-center gap-0.5 py-2.5 text-xs font-medium no-underline"><IconClipboardList class="size-5" aria-hidden="true" />詢問</a>
    </div>
  </div>

  <main id="main-content" class="app-layout max-w-app py-8 pb-24 sm:pb-24">
    <a
      href="/properties"
      class="text-muted-foreground hover:text-accent mb-4 inline-block text-sm no-underline"
    >
      ← 返回在售物件列表
    </a>

    <article>
      <h1 class="text-accent text-2xl font-bold sm:text-3xl">
        {property.data.title}
      </h1>

      <p class="text-muted-foreground mt-2 flex items-center gap-1 text-sm">
        <IconMapPin class="size-4 shrink-0" aria-hidden="true" />
        <span>
          {property.data.district}
          {streetAreaClean ? `・${streetAreaClean}` : ""}
          {property.data.community ? `・${property.data.community}` : ""}
        </span>
      </p>

      {/* 委編 / 專任 / 新上架 / 降價 badge 列 */}
      <div class="mt-3 flex flex-wrap items-center gap-2">
        {fullListingCode && (
          <span class="bg-muted text-muted-foreground inline-block rounded px-2 py-0.5 text-xs">
            委編 {fullListingCode}
          </span>
        )}
        {isExclusive && (
          <span class="inline-block rounded border border-emerald-700 px-2 py-0.5 text-xs font-medium text-emerald-700 dark:border-emerald-400 dark:text-emerald-400">
            本店專任
          </span>
        )}
        {showNewBadge && isNew && (
          <span class="inline-block rounded-full bg-emerald-700 px-2 py-0.5 text-xs font-medium text-white">
            新上架
          </span>
        )}
        {dropPct && (
          <span class="inline-block rounded-full bg-rose-700 px-2 py-0.5 text-xs font-medium text-white">
            降價 {dropPct}%
          </span>
        )}
      </div>

      <div class="text-accent mt-3 flex flex-wrap items-baseline gap-3 text-3xl font-bold sm:text-4xl">
        <span>{formatPrice(property.data.totalPrice)}</span>
        {
          dropPct && property.data.lastPrice && (
            <span class="text-muted-foreground text-lg font-normal line-through">
              {formatPrice(property.data.lastPrice)}
            </span>
          )
        }
        {
          property.data.pricePerPing && (
            <span class="text-muted-foreground text-base font-normal">
              單坪 {property.data.pricePerPing.toFixed(1)} 萬
            </span>
          )
        }
      </div>

      {/* 月付試算（build-time 靜態值，公式見 frontmatter）*/}
      <p class="text-muted-foreground mt-2 text-sm">
        8 成 30 年・利率 2.306% 試算 → 月付約 {monthlyPaymentText} 萬
        <a href="/tools" class="text-accent ml-1 no-underline hover:underline">
          試算工具 →
        </a>
      </p>

      {
        photos.length > 0 ? (
          <div class="my-6" data-gallery>
            {/* 桌面 collage（照片 ≥3 張、sm 以上）：主圖 2x2 + 副圖 2-4 張 */}
            {useCollage && (
              <div
                class="hidden gap-2 sm:grid sm:aspect-[2/1] sm:grid-cols-4 sm:grid-rows-2"
                data-gallery-collage
              >
                <button
                  type="button"
                  data-collage-index="0"
                  class="bg-muted group relative col-span-2 row-span-2 cursor-zoom-in overflow-hidden rounded-lg"
                  aria-label="查看第 1 張"
                >
                  <img
                    src={photos[0]}
                    alt={`${property.data.title}（第 1 張，共 ${photos.length} 張）`}
                    width="800"
                    height="600"
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="eager"
                    fetchpriority="high"
                    decoding="sync"
                  />
                </button>
                {collageSide.map((p, i) => {
                  // 依副圖張數決定 span 避免破格：2 張各佔整排、3 張時最後一張補滿第二排
                  const spanClass =
                    collageSide.length === 2
                      ? "col-span-2"
                      : collageSide.length === 3 && i === 2
                        ? "col-span-2"
                        : "";
                  const isLastTile = i === collageSide.length - 1;
                  return (
                    <button
                      type="button"
