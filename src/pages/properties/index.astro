---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import config from "@/config";
import { safeJsonLd } from "@/utils/safeJsonLd";
import { cleanStreetArea } from "@/utils/cleanStreetArea";
import IconMapPin from "@/assets/icons/IconMapPin.svg";
import IconBuildingCommunity from "@/assets/icons/IconBuildingCommunity.svg";
import IconChevronDown from "@/assets/icons/IconChevronDown.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconCheck from "@/assets/icons/IconCheck.svg";
import IconLine from "@/assets/icons/socials/line.svg";

// 只取 active 的，沒被屋主撤回 / 售出 / 暫停的不顯示
const allProperties = await getCollection(
  "properties",
  ({ data }) => data.status === "active"
);

// 從 title / layout 推類型（純字串 keyword 法）
const TYPE_KEYWORDS: Array<[string, string]> = [
  ["透天", "透天"],
  ["別墅", "別墅"],
  ["店面", "店面"],
  ["套房", "套房"],
  ["農地", "農地"],
  ["建地", "土地"],
  ["土地", "土地"],
  ["林地", "土地"],
  ["商辦", "商辦"],
  ["廠房", "廠房"],
  ["公寓", "公寓"],
  ["華廈", "華廈"],
  ["大樓", "大樓"],
];

function getType(p: (typeof allProperties)[number]): string {
  const t = p.data.title + " " + (p.data.layout || "");
  for (const [kw, label] of TYPE_KEYWORDS) {
    if (t.includes(kw)) return label;
  }
  // 沒命中 → 從格局推：含「房」當大樓 / 公寓
  if (/\d房/.test(p.data.layout || "")) return "大樓";
  return "其他";
}

// 從 layout 抽房數（例「3房2廳2衛」→ 3）
function getRoomBucket(layout: string | undefined): string {
  if (!layout) return "";
  const m = layout.match(/(\d+)\s*房/);
  if (!m) return "";
  const n = parseInt(m[1], 10);
  if (n >= 5) return "5房+";
  return `${n}房`;
}
const ROOM_ORDER = ["1房", "2房", "3房", "4房", "5房+"];

// 台中行政區清單（推薦排序「台中優先」+ 下方 county mapping 共用）
const TAICHUNG = [
  "北屯區",
  "西屯區",
  "南屯區",
  "北區",
  "南區",
  "東區",
  "西區",
  "中區",
  "太平區",
  "大里區",
  "霧峰區",
  "烏日區",
  "大肚區",
  "沙鹿區",
  "梧棲區",
  "清水區",
  "大甲區",
  "外埔區",
  "大安區",
  "龍井區",
  "潭子區",
  "大雅區",
  "神岡區",
  "豐原區",
  "后里區",
  "東勢區",
  "和平區",
  "新社區",
  "石岡區",
];
const TAICHUNG_SET = new Set(TAICHUNG);

// frontmatter 沒有 city/county 欄位 → 用 district 是否在台中行政區清單內判斷
// （dirty data 帶「台中」prefix 也算台中）
function isTaichung(district: string | undefined): boolean {
  if (!district) return false;
  return (
    TAICHUNG_SET.has(district) ||
    district.startsWith("台中") ||
    district.startsWith("臺中")
  );
}

// 推薦排序（複合）：有圖優先 > 台中市優先 > featured > 最新上架。缺圖卡沉到後面。
const sortedProperties = allProperties.sort((a, b) => {
  const coverDiff = (a.data.coverImage ? 0 : 1) - (b.data.coverImage ? 0 : 1);
  if (coverDiff !== 0) return coverDiff;
  const tcDiff =
    (isTaichung(a.data.district) ? 0 : 1) - (isTaichung(b.data.district) ? 0 : 1);
  if (tcDiff !== 0) return tcDiff;
  const featDiff = (a.data.featured ? 0 : 1) - (b.data.featured ? 0 : 1);
  if (featDiff !== 0) return featDiff;
  return b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime();
});

// 標籤判斷
const NEW_LISTING_DAYS = 7;
const now = Date.now();
function isNewListing(p: (typeof allProperties)[number]): boolean {
  if (!p.data.pubDatetime) return false;
  return (now - p.data.pubDatetime.getTime()) / 86400000 <= NEW_LISTING_DAYS;
}
function priceDropPct(p: (typeof allProperties)[number]): number | null {
  if (!p.data.lastPrice || p.data.lastPrice <= p.data.totalPrice) return null;
  return Math.round(
    ((p.data.lastPrice - p.data.totalPrice) / p.data.lastPrice) * 100
  );
}

// 統計 chip 選項 + 數量
const districtCount: Record<string, number> = {};
const typeCount: Record<string, number> = {};
const roomCount: Record<string, number> = {};
let newCount = 0;
let dropCount = 0;

const propertyMeta = sortedProperties.map(p => {
  const district = p.data.district || "未分類";
  const type = getType(p);
  const rooms = getRoomBucket(p.data.layout);
  const newListing = isNewListing(p);
  const dropPct = priceDropPct(p);
  districtCount[district] = (districtCount[district] || 0) + 1;
  typeCount[type] = (typeCount[type] || 0) + 1;
  if (rooms) roomCount[rooms] = (roomCount[rooms] || 0) + 1;
  if (newListing) newCount++;
  if (dropPct) dropCount++;
  return { p, district, type, rooms, newListing, dropPct };
});

// badge 防通膨：pubDatetime 是批次同步日（properties-sync 整批重寫），
// 若全列表超過 30% 物件都判定為「新上架」，代表是同步日 artifact 不是真的新
// → 整批不顯示新上架 badge（含快選 chip）。
// 等 properties-sync 補 firstSeen 欄位後才能恢復精準判定。
const NEW_BADGE_MAX_RATIO = 0.3;
const showNewBadge =
  sortedProperties.length > 0 &&
  newCount / sortedProperties.length <= NEW_BADGE_MAX_RATIO;

// district → county mapping（TAICHUNG 清單已上移至推薦排序前共用）
const COUNTY_MAP: Record<string, string> = {};
const NANTOU = [
  "南投市",
  "草屯鎮",
  "埔里鎮",
  "竹山鎮",
  "集集鎮",
  "名間鄉",
  "中寮鄉",
  "水里鄉",
  "魚池鄉",
  "國姓鄉",
  "信義鄉",
  "仁愛鄉",
  "鹿谷鄉",
];
const CHANGHUA = [
  "彰化市",
  "和美鎮",
  "田中鎮",
  "二林鎮",
  "北斗鎮",
  "員林市",
  "溪湖鎮",
  "鹿港鎮",
  "大村鄉",
  "田尾鄉",
  "秀水鄉",
  "花壇鄉",
  "芬園鄉",
  "福興鄉",
  "線西鄉",
  "伸港鄉",
  "埔鹽鄉",
  "埔心鄉",
  "永靖鄉",
  "社頭鄉",
  "二水鄉",
  "竹塘鄉",
  "溪州鄉",
  "大城鄉",
  "芳苑鄉",
];
const MIAOLI = [
  "苗栗市",
  "竹南鎮",
  "頭份市",
  "卓蘭鎮",
  "苑裡鎮",
  "通霄鎮",
  "後龍鎮",
  "獅潭鄉",
  "泰安鄉",
  "銅鑼鄉",
  "三義鄉",
  "西湖鄉",
  "造橋鄉",
  "公館鄉",
  "三灣鄉",
  "南庄鄉",
  "頭屋鄉",
];
const TAOYUAN = ["中壢區", "八德區", "桃園區", "蘆竹區", "龜山區", "平鎮區"];
const TAIPEI = ["內湖區", "信義區", "大安區", "中山區", "松山區"];
const YUNLIN = ["斗六市", "斗南鎮", "虎尾鎮", "西螺鎮", "土庫鎮", "北港鎮"];

TAICHUNG.forEach(d => (COUNTY_MAP[d] = "台中市"));
NANTOU.forEach(d => (COUNTY_MAP[d] = "南投縣"));
CHANGHUA.forEach(d => (COUNTY_MAP[d] = "彰化縣"));
MIAOLI.forEach(d => (COUNTY_MAP[d] = "苗栗縣"));
TAOYUAN.forEach(d => (COUNTY_MAP[d] = "桃園市"));
TAIPEI.forEach(d => (COUNTY_MAP[d] = "台北市"));
YUNLIN.forEach(d => (COUNTY_MAP[d] = "雲林縣"));

function getCounty(district: string): string {
  // 1. 直接 lookup
  if (COUNTY_MAP[district]) return COUNTY_MAP[district];
  // 2. dirty district 含縣市 prefix（例「南投中寮區」「南投縣國姓鄉」）
  for (const [prefix, county] of [
    ["南投", "南投縣"],
    ["彰化", "彰化縣"],
    ["苗栗", "苗栗縣"],
    ["雲林", "雲林縣"],
    ["桃園", "桃園市"],
    ["台北", "台北市"],
    ["臺北", "台北市"],
    ["台中", "台中市"],
    ["臺中", "台中市"],
  ] as const) {
    if (district.startsWith(prefix)) return county;
  }
  // 3. fallback：含「鄉」多半南投彰化苗栗，但無法分 → 「其他」
  return "其他";
}

// 縣市順序（按筆數）
const COUNTY_ORDER = [
  "台中市",
  "彰化縣",
  "南投縣",
  "苗栗縣",
  "桃園市",
  "台北市",
  "雲林縣",
  "其他",
];

// district 按 county group
const districtsByCounty: Record<string, Array<[string, number]>> = {};
for (const [d, n] of Object.entries(districtCount)) {
  const c = getCounty(d);
  (districtsByCounty[c] ||= []).push([d, n]);
}
// 每縣市內按筆數排
for (const c of Object.keys(districtsByCounty)) {
  districtsByCounty[c].sort((a, b) => b[1] - a[1]);
}
// 縣市排序（依 COUNTY_ORDER + 筆數）
const counties = COUNTY_ORDER.filter(c => districtsByCounty[c]);

// 篩選收斂：預設只露台中市筆數前 8 行政區，長尾 + 其他縣市收進「更多區域」
const TOP_DISTRICTS = 8;
const taichungDistricts = districtsByCounty["台中市"] ?? [];
const taichungTop = taichungDistricts.slice(0, TOP_DISTRICTS);
const taichungRest = taichungDistricts.slice(TOP_DISTRICTS);
const otherCounties = counties.filter(c => c !== "台中市");

const types = Object.entries(typeCount).sort((a, b) => b[1] - a[1]);

const rooms = ROOM_ORDER.filter(r => roomCount[r]).map(
  r => [r, roomCount[r]] as [string, number]
);

const formatPrice = (price: number) => {
  if (price >= 10000) return `${(price / 10000).toFixed(2)} 億`;
  return `${price.toLocaleString()} 萬`;
};

// ============ SEO + JSON-LD ============
const canonicalURL = new URL("/properties", Astro.site).href;
const seoDescription = `${sortedProperties.length} 筆台中精選在售物件 — 北屯 / 西屯 / 南屯 / 七期 / 太平 / 大里。含本店同事聯賣案件，每筆都有實坪 / 屋齡 / 樓層 / 車位明細，景泰實價整理。`;

// ItemList JSON-LD（給 Google 認識這是物件列表頁、可進 Google 物件搜尋）
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `${canonicalURL}#listing`,
  name: "台中在售物件",
  description: seoDescription,
  numberOfItems: sortedProperties.length,
  itemListElement: sortedProperties.slice(0, 30).map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: new URL(`/properties/${p.id}`, Astro.site).href,
    name: p.data.title,
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "首頁",
      item: new URL("/", Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "在售物件",
      item: canonicalURL,
    },
  ],
};
---

<Layout
  title={`在售物件 ${sortedProperties.length} 筆 | ${config.site.title}`}
  description={seoDescription}
  canonicalURL={canonicalURL}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(itemListSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={safeJsonLd(breadcrumbSchema)}
    />
  </Fragment>

  <Header />

  <Main
    pageTitle="在售物件"
    pageDesc={`${sortedProperties.length} 筆精選物件以台中為主，含本店跨縣市聯賣案件。`}
  >
    <!-- 篩選列 -->
    <div class="card-surface mb-6 space-y-3 p-4">
      <!-- 手機篩選收合開關（sm 以上恆展開） -->
      <button
        type="button"
        data-filter-toggle
        aria-expanded="false"
        class="text-foreground flex min-h-11 w-full cursor-pointer items-center justify-between text-sm font-medium sm:hidden"
      >
        篩選條件
        <IconChevronDown
          class="size-5 transition-transform"
          aria-hidden="true"
          data-filter-toggle-icon
        />
      </button>

      <div class="hidden space-y-4 sm:block" data-filter-body>
        <!-- 快選（降價；新上架 chip 受 showNewBadge 防通膨判定，目前不顯示） -->
        <div>
          <div class="text-muted-foreground mb-2 text-xs font-medium">快選</div>
          <div
            class="flex flex-wrap gap-2"
            data-filter-group="quick"
            role="group"
            aria-label="快選篩選"
          >
            <button
              type="button"
              data-filter-value=""
              class="filter-chip filter-chip-active"
            >
              全部
            </button>
            {
              showNewBadge && newCount > 0 && (
                <button
                  type="button"
                  data-filter-value="new"
                  class="filter-chip"
                >
                  新上架 ({newCount})
                </button>
              )
            }
            {
              dropCount > 0 && (
                <button
                  type="button"
                  data-filter-value="drop"
                  class="filter-chip"
                >
                  降價中 ({dropCount})
                </button>
              )
            }
          </div>
        </div>

        <!-- 區域：預設露台中前 8 區，其餘收進「更多區域」 -->
        <div>
          <div class="text-muted-foreground mb-2 text-xs font-medium">區域</div>
          <div
            class="space-y-2"
            data-filter-group="district"
            role="group"
            aria-label="區域篩選"
          >
            <div class="flex flex-wrap gap-2">
              <button
                type="button"
                data-filter-value=""
                class="filter-chip filter-chip-active"
              >
                全部 ({sortedProperties.length})
              </button>
              {
                taichungTop.map(([d, n]) => (
                  <button type="button" data-filter-value={d} class="filter-chip">
                    {d} ({n})
                  </button>
                ))
              }
            </div>
            {
              (taichungRest.length > 0 || otherCounties.length > 0) && (
                <details class="group">
                  <summary class="text-muted-foreground hover:text-accent flex cursor-pointer items-center gap-1 text-sm select-none">
                    更多區域
                    <IconChevronDown
                      class="size-4 transition-transform group-open:rotate-180"
                      aria-hidden="true"
                    />
                  </summary>
                  <div class="mt-2 space-y-2">
                    {taichungRest.length > 0 && (
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="text-muted-foreground w-14 shrink-0 text-xs font-medium">
                          台中市
                        </span>
                        {taichungRest.map(([d, n]) => (
                          <button
                            type="button"
                            data-filter-value={d}
                            class="filter-chip"
                          >
                            {d} ({n})
                          </button>
                        ))}
                      </div>
                    )}
                    {otherCounties.map(c => (
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="text-muted-foreground w-14 shrink-0 text-xs font-medium">
                          {c}
                        </span>
                        {districtsByCounty[c].map(([d, n]) => (
                          <button
                            type="button"
                            data-filter-value={d}
                            class="filter-chip"
                          >
                            {d} ({n})
                          </button>
                        ))}
                      </div>
                    ))}
                  </div>
                </details>
              )
            }
          </div>
        </div>

        <!-- 總價 range + 快選 -->
        <div>
          <div class="text-muted-foreground mb-2 text-xs font-medium">總價</div>
          <div class="flex flex-wrap items-center gap-2">
            <input
              type="number"
              inputmode="numeric"
              min="0"
              step="50"
              placeholder="不限"
              aria-label="總價下限（萬）"
              class="filter-range-input"
              data-filter-range="priceMin"
            />
            <span class="text-muted-foreground text-sm">~</span>
            <input
              type="number"
              inputmode="numeric"
              min="0"
              step="50"
              placeholder="不限"
              aria-label="總價上限（萬）"
              class="filter-range-input"
              data-filter-range="priceMax"
            />
            <span class="text-muted-foreground text-sm">萬</span>
          </div>
          <div class="mt-2 flex flex-wrap gap-2" data-filter-quick="price">
            <button
              type="button"
              data-quick-min=""
              data-quick-max="500"
              class="filter-chip"
            >
              500 萬以下
            </button>
            <button
              type="button"
              data-quick-min="500"
              data-quick-max="1000"
              class="filter-chip"
            >
              500–1000 萬
            </button>
            <button
              type="button"
              data-quick-min="1000"
              data-quick-max="2000"
              class="filter-chip"
            >
              1000–2000 萬
            </button>
            <button
              type="button"
              data-quick-min="2000"
              data-quick-max="3000"
              class="filter-chip"
            >
              2000–3000 萬
            </button>
            <button
              type="button"
              data-quick-min="3000"
              data-quick-max="5000"
              class="filter-chip"
            >
              3000–5000 萬
            </button>
            <button
              type="button"
              data-quick-min="5000"
              data-quick-max=""
              class="filter-chip"
            >
              5000 萬以上
            </button>
          </div>
        </div>

        <!-- 更多條件：類型 / 房型 / 屋齡 收斂進 details -->
        <details class="group">
          <summary
            class="text-muted-foreground hover:text-accent flex cursor-pointer items-center gap-1 text-sm select-none"
          >
            更多條件（類型・房型・屋齡）
            <IconChevronDown
              class="size-4 transition-transform group-open:rotate-180"
              aria-hidden="true"
            />
          </summary>
          <div class="mt-3 space-y-4">
            <!-- 類型 -->
            <div>
              <div class="text-muted-foreground mb-2 text-xs font-medium">
                類型
              </div>
              <div
                class="flex flex-wrap gap-2"
                data-filter-group="type"
                role="group"
                aria-label="物件類型篩選"
              >
                <button
                  type="button"
                  data-filter-value=""
                  class="filter-chip filter-chip-active"
                >
                  全部
                </button>
                {
                  types.map(([t, n]) => (
                    <button
                      type="button"
                      data-filter-value={t}
                      class="filter-chip"
                    >
                      {t} ({n})
                    </button>
                  ))
                }
              </div>
            </div>

            <!-- 房型（幾房） -->
            {
              rooms.length > 0 && (
                <div>
                  <div class="text-muted-foreground mb-2 text-xs font-medium">
                    房型
                  </div>
                  <div
                    class="flex flex-wrap gap-2"
                    data-filter-group="rooms"
                    role="group"
                    aria-label="房型篩選"
                  >
                    <button
                      type="button"
                      data-filter-value=""
                      class="filter-chip filter-chip-active"
                    >
                      全部
                    </button>
                    {rooms.map(([r, n]) => (
                      <button
                        type="button"
                        data-filter-value={r}
                        class="filter-chip"
                      >
                        {r} ({n})
                      </button>
                    ))}
                  </div>
                </div>
              )
            }

            <!-- 屋齡 range -->
            <div>
              <div class="text-muted-foreground mb-2 text-xs font-medium">
                屋齡
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <input
                  type="number"
                  inputmode="numeric"
                  min="0"
                  step="1"
                  placeholder="不限"
                  aria-label="屋齡下限（年）"
                  class="filter-range-input"
                  data-filter-range="ageMin"
                />
                <span class="text-muted-foreground text-sm">~</span>
                <input
                  type="number"
                  inputmode="numeric"
                  min="0"
                  step="1"
                  placeholder="不限"
                  aria-label="屋齡上限（年）"
                  class="filter-range-input"
                  data-filter-range="ageMax"
                />
                <span class="text-muted-foreground text-sm">年</span>
              </div>
              <div class="mt-2 flex flex-wrap gap-2" data-filter-quick="age">
                <button
                  type="button"
                  data-quick-min=""
                  data-quick-max="5"
                  class="filter-chip"
                >
                  新成屋（≤5 年）
                </button>
                <button
                  type="button"
                  data-quick-min=""
                  data-quick-max="15"
                  class="filter-chip"
                >
                  15 年內
                </button>
                <button
                  type="button"
                  data-quick-min="15"
                  data-quick-max="30"
                  class="filter-chip"
                >
                  15–30 年
                </button>
                <button
                  type="button"
                  data-quick-min="30"
                  data-quick-max=""
                  class="filter-chip"
                >
                  30 年以上
                </button>
              </div>
            </div>
          </div>
        </details>
      </div>

      <!-- 結果計數（醒目）+ 排序控制 — 不收進手機收合區，恆顯示 -->
      <div
        class="border-border flex flex-wrap items-center justify-between gap-3 border-t pt-3"
        data-filter-summary
      >
        <div class="text-foreground text-sm font-medium">
          顯示 <span
            class="text-accent text-lg font-extrabold"
            data-filter-count>{sortedProperties.length}</span
          > 筆
        </div>
        <label class="flex items-center gap-2">
          <span class="text-muted-foreground text-xs">排序</span>
          <select data-sort-select aria-label="排序方式" class="sort-select">
            <option value="recommended" selected>推薦排序</option>
            <option value="price-asc">總價低→高</option>
            <option value="price-desc">總價高→低</option>
            <option value="newest">最新上架</option>
          </select>
        </label>
      </div>
    </div>

    {
      sortedProperties.length === 0 ? (
        <p class="text-muted-foreground py-12 text-center">
          目前沒有開放公開的物件，
          <a href="https://line.me/ti/p/sky811117" class="text-accent underline">
            LINE 私訊
          </a>
          了解未公開物件。
        </p>
      ) : (
        <ul
          class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
          data-property-list
        >
          {propertyMeta.map(({ p: property, district, type, rooms, newListing, dropPct }, idx) => (
            <li
              class="card-interactive overflow-hidden"
              data-district={district}
              data-type={type}
              data-rooms={rooms}
              data-price={property.data.totalPrice}
              data-age={property.data.age ?? ""}
              data-pub={property.data.pubDatetime.getTime()}
              data-order={idx}
              data-quick={[newListing ? "new" : "", dropPct ? "drop" : ""].filter(Boolean).join(" ")}
            >
              <a
                href={`/properties/${property.id}`}
                class="block no-underline"
                data-track="property"
                data-property-id={property.id}
                data-property-title={property.data.title}
                data-property-price={String(property.data.totalPrice)}
                data-property-district={district}
              >
                {property.data.coverImage ? (
                  <div class="bg-muted aspect-[4/3] w-full overflow-hidden">
                    <img
                      src={
                        typeof property.data.coverImage === "string"
                          ? property.data.coverImage
                          : property.data.coverImage.src
                      }
                      alt={property.data.title}
                      width="800"
                      height="600"
                      class="h-full w-full object-cover"
                      loading={idx < 3 ? "eager" : "lazy"}
                      fetchpriority={idx === 0 ? "high" : undefined}
                      decoding={idx < 3 ? "sync" : "async"}
                    />
                  </div>
                ) : (
                  <div class="bg-muted flex aspect-[4/3] w-full flex-col items-center justify-center gap-2 overflow-hidden">
                    <IconBuildingCommunity
                      class="text-muted-foreground/50 size-16"
                      aria-hidden="true"
                    />
                    <p class="text-muted-foreground text-xs">
                      想看實照？LINE 問景泰
                    </p>
                  </div>
                )}

                <div class="p-4">
                  <div class="mb-2 flex flex-wrap gap-1">
                    {property.data.featured && (
                      <span class="bg-accent text-accent-foreground inline-block rounded-full px-2 py-0.5 text-xs">
                        精選
                      </span>
                    )}
                    {showNewBadge && newListing && (
                      <span class="inline-block rounded-full bg-emerald-700 px-2 py-0.5 text-xs text-white">
                        新上架
                      </span>
                    )}
                    {dropPct && (
                      <span class="inline-block rounded-full bg-rose-700 px-2 py-0.5 text-xs text-white">
                        降價 {dropPct}%
                      </span>
                    )}
                    <span class="bg-muted text-muted-foreground inline-block rounded-full px-2 py-0.5 text-xs">
                      {type}
                    </span>
                  </div>

                  <h2 class="text-foreground line-clamp-2 text-lg font-bold">
                    {property.data.title}
                  </h2>

                  <p class="text-muted-foreground mt-1 flex items-center gap-1 text-sm">
                    <IconMapPin class="size-4 shrink-0" aria-hidden="true" />
                    <span class="line-clamp-1">
                      {property.data.district}
                      {cleanStreetArea(
                        property.data.streetArea,
                        property.data.district
                      )
                        ? `・${cleanStreetArea(property.data.streetArea, property.data.district)}`
                        : ""}
                    </span>
                  </p>

                  <div class="mt-3 flex items-baseline gap-2">
                    <span class="text-accent text-2xl font-extrabold">
                      {formatPrice(property.data.totalPrice)}
                    </span>
                    {dropPct && property.data.lastPrice && (
                      <span class="text-muted-foreground text-sm line-through">
                        {formatPrice(property.data.lastPrice)}
                      </span>
                    )}
                    {property.data.pricePerPing && (
                      <span class="text-muted-foreground ml-auto text-xs">
                        {property.data.pricePerPing.toFixed(1)} 萬/坪
                      </span>
                    )}
                  </div>

                  <div class="text-muted-foreground mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm">
                    <span>{property.data.layout}</span>
                    <span>·</span>
                    <span>{property.data.area} 坪</span>
                    {property.data.floor && (
                      <>
                        <span>·</span>
                        <span>{property.data.floor}</span>
                      </>
                    )}
                    {property.data.age !== undefined && (
                      <>
                        <span>·</span>
                        <span>屋齡 {property.data.age} 年</span>
                      </>
                    )}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }

    <div
      class="card-surface hidden px-6 py-10 text-center sm:px-8 sm:py-12"
      data-filter-empty
    >
      <div class="bg-accent/10 mx-auto w-fit rounded-xl p-3">
        <IconSearch class="text-accent size-8" aria-hidden="true" />
      </div>
      <h3 class="text-foreground mt-4 text-xl font-bold sm:text-2xl">
        沒有完全符合條件的物件
      </h3>
      <p class="text-muted-foreground mt-3 text-[15px] leading-relaxed">
        試試放寬條件 — 我手上常有未公開物件、跟你的條件可能對得上。
      </p>

      <ul
        class="text-foreground mx-auto mt-5 max-w-md space-y-2 text-left text-[15px] leading-relaxed"
      >
        <li class="flex items-start gap-2">
          <IconCheck class="text-accent mt-1 size-4 shrink-0" aria-hidden="true" />
          <span>試試 <strong>清空所有條件</strong> 看完整 list</span>
        </li>
        <li class="flex items-start gap-2">
          <IconCheck class="text-accent mt-1 size-4 shrink-0" aria-hidden="true" />
          <span>把<strong>總價上限</strong>加 100-200 萬看更多選擇</span>
        </li>
        <li class="flex items-start gap-2">
          <IconCheck class="text-accent mt-1 size-4 shrink-0" aria-hidden="true" />
          <span>試試<strong>相鄰行政區</strong>（例 北屯 → 太平 / 西屯 → 北區）</span>
        </li>
      </ul>

      <div
        class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4"
      >
        <button type="button" data-filter-reset class="btn-outline text-[15px]">
          清空篩選
        </button>
        <a href="https://line.me/ti/p/sky811117" class="btn-line text-[15px]">
          <IconLine class="size-5" aria-hidden="true" />
          LINE 告訴我需求
        </a>
      </div>

      <p class="text-muted-foreground mt-5 text-[13px]">
        景泰會聯絡有相似物件的同事、24 小時內回覆。
      </p>
    </div>

    <div class="border-border mt-12 rounded-card border border-dashed p-6 text-center">
      <p class="text-muted-foreground mb-3 text-sm">
        看到喜歡的物件？或想看未公開物件？
      </p>
      <a href="https://line.me/ti/p/sky811117" class="btn-line">
        <IconLine class="size-5" aria-hidden="true" />
        LINE 私訊 sky811117
      </a>
      <p class="text-muted-foreground mt-4 text-xs">
        一品不動產 有巢氏房屋 台中世界之心加盟店<br />
        經紀人 黃永隆 113彰縣字324 ・ 營業員 陳景泰 114登字488296
      </p>
    </div>
  </Main>

  <Footer />
</Layout>

<style>
  .filter-chip {
    cursor: pointer;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: var(--background);
    color: var(--foreground);
    padding: 0.25rem 0.75rem;
    font-size: 0.875rem;
    transition:
      border-color 0.15s,
      background-color 0.15s,
      color 0.15s;
  }
  .filter-chip:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .filter-chip-active,
  .filter-chip-active:hover {
    border-color: var(--accent);
    background: var(--accent);
    color: var(--background);
  }
  .filter-range-input {
    width: 5.5rem;
    border-radius: 0.375rem;
    border: 1px solid var(--border);
    background: var(--background);
    color: var(--foreground);
    padding: 0.25rem 0.5rem;
    font-size: 1rem;
    text-align: center;
    transition: border-color 0.15s;
  }
  .filter-range-input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .filter-range-input::-webkit-outer-spin-button,
  .filter-range-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .filter-range-input[type="number"] {
    -moz-appearance: textfield;
  }
  .sort-select {
    cursor: pointer;
    border-radius: 0.375rem;
    border: 1px solid var(--border);
    background: var(--background);
    color: var(--foreground);
    padding: 0.375rem 0.5rem;
    font-size: 0.875rem;
    transition: border-color 0.15s;
  }
  .sort-select:focus {
    outline: none;
    border-color: var(--accent);
  }
</style>

<script is:inline>
  (function () {
    const groups = document.querySelectorAll("[data-filter-group]");
    const quickRanges = document.querySelectorAll("[data-filter-quick]");
    const rangeInputs = document.querySelectorAll("[data-filter-range]");
    const list = document.querySelector("[data-property-list]");
    if (!list) return;
    const items = Array.from(list.children);
    const countEl = document.querySelector("[data-filter-count]");
    const emptyEl = document.querySelector("[data-filter-empty]");

    const state = {
      district: "",
      type: "",
      rooms: "",
      quick: "",
      priceMin: "",
      priceMax: "",
      ageMin: "",
      ageMax: "",
    };
    const CHIP_KEYS = ["district", "type", "rooms", "quick"];
    const RANGE_KEYS = ["priceMin", "priceMax", "ageMin", "ageMax"];
    const ALL_KEYS = CHIP_KEYS.concat(RANGE_KEYS);

    function num(v) {
      if (v === "" || v === null || v === undefined) return null;
      const n = parseFloat(v);
      return isNaN(n) ? null : n;
    }

    function apply() {
      const pMin = num(state.priceMin);
      const pMax = num(state.priceMax);
      const aMin = num(state.ageMin);
      const aMax = num(state.ageMax);
      const ageActive = aMin !== null || aMax !== null;
      let visible = 0;
      for (const li of items) {
        const okD = !state.district || li.dataset.district === state.district;
        const okT = !state.type || li.dataset.type === state.type;
        const okR = !state.rooms || li.dataset.rooms === state.rooms;

        const priceNum = num(li.dataset.price);
        // 價格 filter 沒啟用時一律通過，避免缺價格的卡被無聲隱藏
        const priceActive = pMin !== null || pMax !== null;
        const okP =
          !priceActive ||
          (priceNum !== null &&
            (pMin === null || priceNum >= pMin) &&
            (pMax === null || priceNum <= pMax));

        let okA = true;
        if (ageActive) {
          const ageNum = num(li.dataset.age);
          if (ageNum === null) {
            okA = false; // 啟用屋齡 filter 但物件沒填 → 藏掉
          } else {
            okA =
              (aMin === null || ageNum >= aMin) &&
              (aMax === null || ageNum <= aMax);
          }
        }

        // quick 是空白分隔多值，contains check
        const quickTokens = (li.dataset.quick || "")
          .split(/\s+/)
          .filter(Boolean);
        const okQ = !state.quick || quickTokens.includes(state.quick);

        const show = okD && okT && okR && okP && okA && okQ;
        li.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (countEl) countEl.textContent = String(visible);
      if (emptyEl) emptyEl.classList.toggle("hidden", visible !== 0);
      list.classList.toggle("hidden", visible === 0);
      syncQuickRangeActive();
      syncUrl();
    }

    function syncUrl() {
      const url = new URL(location.href);
      ALL_KEYS.forEach(k => {
        if (state[k]) url.searchParams.set(k, state[k]);
        else url.searchParams.delete(k);
      });
      history.replaceState(null, "", url.toString());
    }

    function setChipActive(group, value) {
      group.querySelectorAll(".filter-chip").forEach(b => {
        const match = (b.dataset.filterValue || "") === value;
        b.classList.toggle("filter-chip-active", match);
        b.setAttribute("aria-pressed", match ? "true" : "false");
      });
    }

    // quick-range chip 的 active 狀態：min/max 完全等於 state 才 active
    function syncQuickRangeActive() {
      quickRanges.forEach(group => {
        const prefix = group.dataset.filterQuick; // "price" or "age"
        const minKey = prefix + "Min";
        const maxKey = prefix + "Max";
        group.querySelectorAll(".filter-chip").forEach(b => {
          const match =
            (b.dataset.quickMin || "") === (state[minKey] || "") &&
            (b.dataset.quickMax || "") === (state[maxKey] || "");
          b.classList.toggle("filter-chip-active", match);
          b.setAttribute("aria-pressed", match ? "true" : "false");
        });
      });
    }

    function syncRangeInputs() {
      rangeInputs.forEach(inp => {
        const key = inp.dataset.filterRange;
        inp.value = state[key] || "";
      });
    }

    // 初始 URL state
    const params = new URLSearchParams(location.search);
    ALL_KEYS.forEach(k => {
      const v = params.get(k);
      if (v) state[k] = v;
    });
    syncRangeInputs();

    // chip group：district / type / rooms / quick
    groups.forEach(g => {
      const key = g.dataset.filterGroup;
      setChipActive(g, state[key] || "");
      g.addEventListener("click", e => {
        const btn = e.target.closest(".filter-chip");
        if (!btn) return;
        const v = btn.dataset.filterValue || "";
        state[key] = v;
        setChipActive(g, v);
        apply();
      });
    });

    // quick-range chip：price / age 快選
    quickRanges.forEach(g => {
      const prefix = g.dataset.filterQuick;
      const minKey = prefix + "Min";
      const maxKey = prefix + "Max";
      g.addEventListener("click", e => {
        const btn = e.target.closest(".filter-chip");
        if (!btn) return;
        const min = btn.dataset.quickMin || "";
        const max = btn.dataset.quickMax || "";
        // 點到已 active 的 chip → 清空（toggle off）
        const alreadyActive = btn.classList.contains("filter-chip-active");
        state[minKey] = alreadyActive ? "" : min;
        state[maxKey] = alreadyActive ? "" : max;
        syncRangeInputs();
        apply();
      });
    });

    // range input：min / max number 輸入
    rangeInputs.forEach(inp => {
      const key = inp.dataset.filterRange;
      inp.addEventListener("input", () => {
        state[key] = inp.value.trim();
        apply();
      });
    });

    // 清空篩選按鈕（空狀態 UI 內）
    document.querySelectorAll("[data-filter-reset]").forEach(btn => {
      btn.addEventListener("click", () => {
        ALL_KEYS.forEach(k => {
          state[k] = "";
        });
        // 同步 UI：所有 chip group reset 到 "" (全部)
        groups.forEach(g => setChipActive(g, ""));
        syncQuickRangeActive();
        syncRangeInputs();
        apply();
        // scroll 回篩選列頂部讓用戶看到 reset 結果
        const filterBar = document.querySelector("[data-filter-group='district']");
        if (filterBar) filterBar.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    apply();

    // 深連結進來時，active chip 若藏在 <details>（更多區域 / 更多條件）裡 → 自動展開
    // 注意：data-filter-value 為空字串 =「全部」chip（預設 active）→ 跳過，避免每次載入都展開
    document.querySelectorAll(".filter-chip-active").forEach(chip => {
      if (!chip.dataset.filterValue) return;
      const det = chip.closest("details");
      if (det) det.open = true;
    });
  })();

  // 手機篩選收合：sm 以下預設收起，點「篩選條件」展開（sm 以上 CSS 恆顯示）
  (function () {
    const btn = document.querySelector("[data-filter-toggle]");
    const body = document.querySelector("[data-filter-body]");
    const icon = document.querySelector("[data-filter-toggle-icon]");
    if (!btn || !body) return;
    btn.addEventListener("click", () => {
      const opened = body.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", opened ? "true" : "false");
      if (icon) icon.classList.toggle("rotate-180", opened);
    });
  })();

  // 排序控制：client-side 重排卡片 DOM（不動 filter 顯示狀態）
  (function () {
    const select = document.querySelector("[data-sort-select]");
    const list = document.querySelector("[data-property-list]");
    if (!select || !list) return;

    function val(li, key) {
      const n = parseFloat(li.dataset[key]);
      return isNaN(n) ? 0 : n;
    }

    select.addEventListener("change", () => {
      const v = select.value;
      const items = Array.from(list.children);
      items.sort((a, b) => {
        if (v === "price-asc") return val(a, "price") - val(b, "price");
        if (v === "price-desc") return val(b, "price") - val(a, "price");
        if (v === "newest") return val(b, "pub") - val(a, "pub");
        // 推薦排序 = build-time 複合排序（data-order 還原）
        return val(a, "order") - val(b, "order");
      });
      items.forEach(li => list.appendChild(li));
    });
  })();
</script>
